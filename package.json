{
  "name": "@community-data-libraries/web",
  "version": "1.0.0",
  "description": "Community Data Libraries - A curated collection of data science resources and community-submitted materials",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "validate:geo": "node scripts/validate-geojson.mjs",
    "validate:schema": "node scripts/validate-geojson.mjs",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.astro",
    "format": "prettier --write .",
    "check": "npm run lint && npm run validate:geo && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/community-data-libraries/web.git"
  },
  "keywords": [
    "data-science",
    "community",
    "library",
    "resources",
    "astro",
    "react"
  ],
  "author": "Community Data Libraries",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/community-data-libraries/web/issues"
  },
  "homepage": "https://github.com/community-data-libraries/web#readme",
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "astro": "^5.17.2",
    "flowbite": "^4.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@mapbox/geojsonhint": "^3.3.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "astro-eslint-parser": "^0.16.3",
    "autoprefixer": "^10.4.24",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^0.34.0",
    "eslint-plugin-prettier": "^5.1.3",
    "postcss": "^8.5.6",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.1.18"
  }
}

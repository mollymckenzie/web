---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/web/', label: 'Home' },
  { href: '/web/master-library', label: 'Master Library' },
  { href: '/web/community-library', label: 'Community' },
  { href: '/web/maps', label: 'Map' },
  { href: '/web/data-preview', label: 'Data Preview' },
];

function isActive(href: string, path: string): boolean {
  if (href === '/web/') return path === '/web/' || path === '/web';
  return path.startsWith(href);
}
---

<nav class="navbar" role="navigation" aria-label="Main navigation">
  <div class="nav-container">

    <!-- Brand -->
    <div class="nav-brand">
      <a href="/web/" class="brand-link">
        <span class="brand-mark">CDL</span>
        <span class="brand-name">Community<br/>Data Libraries</span>
      </a>
    </div>

    <!-- Desktop links -->
    <ul class="nav-links" id="nav-links">
      {navItems.map((item) => (
        <li class="nav-item">
          <a
            href={item.href}
            class={`nav-link ${isActive(item.href, currentPath) ? 'active' : ''}`}
            aria-current={isActive(item.href, currentPath) ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA + hamburger -->
    <div class="nav-actions">
      <a href="/web/submit" class="nav-cta">Submit Resource</a>
      <button
        class="mobile-menu-button"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        id="mobile-menu-button"
      >
        <span class="hb"></span>
        <span class="hb"></span>
        <span class="hb"></span>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
    <ul class="mobile-links">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class={`mobile-link ${isActive(item.href, currentPath) ? 'active' : ''}`}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li><a href="/web/submit" class="mobile-link mobile-link-cta">Submit a Resource →</a></li>
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-button');
  const drawer = document.getElementById('mobile-drawer');

  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    btn.classList.toggle('open', !open);
    drawer?.classList.toggle('open', !open);
    drawer?.setAttribute('aria-hidden', String(open));
  });

  document.addEventListener('click', (e) => {
    if (!(e.target instanceof Element)) return;
    if (!e.target.closest('.navbar')) {
      btn?.setAttribute('aria-expanded', 'false');
      btn?.classList.remove('open');
      drawer?.classList.remove('open');
      drawer?.setAttribute('aria-hidden', 'true');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      btn?.setAttribute('aria-expanded', 'false');
      btn?.classList.remove('open');
      drawer?.classList.remove('open');
      drawer?.setAttribute('aria-hidden', 'true');
    }
  });
</script>

<style>
  /* ── Navbar shell ─────────────────────────────── */
  .navbar {
    background: rgba(249, 245, 238, 0.92);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(16px) saturate(160%);
    -webkit-backdrop-filter: blur(16px) saturate(160%);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-6);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    height: 64px;
  }

  /* ── Brand ────────────────────────────────────── */
  .nav-brand { flex-shrink: 0; }

  .brand-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .brand-link:hover { opacity: 0.8; text-decoration: none; }

  .brand-mark {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.1rem;
    letter-spacing: -0.04em;
    color: #FFF8F4;
    background: var(--color-primary);
    padding: 0.2em 0.45em 0.18em;
    border-radius: var(--radius-sm);
    line-height: 1;
    flex-shrink: 0;
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  /* ── Desktop nav links ────────────────────────── */
  .nav-links {
    display: none;
    list-style: none;
    gap: var(--space-1);
    margin: 0;
    padding: 0;
  }

  @media (min-width: 768px) {
    .nav-links { display: flex; }
  }

  .nav-item { margin: 0; }

  .nav-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
    position: relative;
  }

  .nav-link:hover {
    background: var(--color-primary-glow);
    color: var(--color-primary);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--color-primary);
    font-weight: 600;
    background: var(--color-primary-glow);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: var(--space-3);
    right: var(--space-3);
    height: 2px;
    background: var(--color-primary);
    border-radius: 1px;
  }

  /* ── Nav actions ──────────────────────────────── */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .nav-cta {
    display: none;
    padding: var(--space-2) var(--space-4);
    background: var(--color-primary);
    color: #FFF8F4;
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.18s ease;
    white-space: nowrap;
    border: 1.5px solid var(--color-primary);
  }

  .nav-cta:hover {
    background: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
    box-shadow: var(--shadow-glow-primary);
    transform: translateY(-1px);
    text-decoration: none;
    color: #FFF8F4;
  }

  @media (min-width: 640px) {
    .nav-cta { display: inline-flex; align-items: center; }
  }

  /* ── Hamburger ────────────────────────────────── */
  .mobile-menu-button {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 38px;
    height: 38px;
    background: transparent;
    border: 1.5px solid var(--color-border);
    cursor: pointer;
    border-radius: var(--radius-md);
    transition: border-color 0.15s ease, background 0.15s ease;
    padding: 0;
    flex-shrink: 0;
  }

  .mobile-menu-button:hover {
    background: var(--color-primary-glow);
    border-color: var(--color-primary);
    box-shadow: none;
    transform: none;
  }

  .hb {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--color-text-muted);
    border-radius: 2px;
    transition: all 0.22s ease;
    transform-origin: center;
  }

  .mobile-menu-button.open .hb:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
    background: var(--color-primary);
  }
  .mobile-menu-button.open .hb:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .mobile-menu-button.open .hb:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
    background: var(--color-primary);
  }

  @media (min-width: 768px) {
    .mobile-menu-button { display: none; }
  }

  /* ── Mobile drawer ────────────────────────────── */
  .mobile-drawer {
    display: none;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) var(--space-6);
    box-shadow: var(--shadow-md);
  }

  .mobile-drawer.open {
    display: block;
  }

  @media (min-width: 768px) {
    .mobile-drawer { display: none !important; }
  }

  .mobile-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-1);
  }

  .mobile-link {
    display: block;
    padding: var(--space-3) var(--space-4);
    font-size: var(--font-size-base);
    font-weight: 500;
    color: var(--color-text-muted);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .mobile-link:hover {
    background: var(--color-primary-glow);
    color: var(--color-primary);
    text-decoration: none;
  }

  .mobile-link.active {
    color: var(--color-primary);
    font-weight: 600;
    background: var(--color-primary-glow);
  }

  .mobile-link-cta {
    color: var(--color-primary);
    font-weight: 700;
    border: 1.5px solid var(--color-border);
    text-align: center;
    margin-top: var(--space-2);
  }

  .mobile-link-cta:hover {
    background: var(--color-primary);
    color: #FFF8F4;
    border-color: var(--color-primary);
  }
</style>

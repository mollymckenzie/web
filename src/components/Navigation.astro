---
import { withBasePath } from '@lib/paths';

const currentPath = Astro.url.pathname;

const homeHref = withBasePath('/');
const catalogHref = withBasePath('/complete-catalog');
const communityHref = withBasePath('/community-library');
const mapHref = withBasePath('/maps');
const dataResourcesHref = withBasePath('/data-resources');
const submitHref = withBasePath('/submit');

const navItems = [
  { href: homeHref, label: 'Home' },
  { href: catalogHref, label: 'Complete Catalog' },
  { href: communityHref, label: 'Community' },
  { href: mapHref, label: 'Map' },
];

const dataResourcesItems = [
  { href: submitHref, label: 'Suggest a Data Resource' },
  { href: `${dataResourcesHref}#lesson-plans`, label: 'Lesson Plans & Resources' },
  { href: `${dataResourcesHref}#community-activities`, label: 'Community Activities' },
];

function isActive(href: string, path: string): boolean {
  if (href === homeHref) return path === homeHref || path === homeHref.slice(0, -1);
  return path.startsWith(href);
}

function isDataResourcesActive(path: string): boolean {
  return path.startsWith(dataResourcesHref);
}
---

<nav class="navbar" role="navigation" aria-label="Main navigation">
  <div class="nav-container">

    <!-- Brand -->
    <div class="nav-brand">
      <a href={homeHref} class="brand-link">
        <span class="brand-mark">CDL</span>
        <span class="brand-name">Community<br/>Data Libraries</span>
      </a>
    </div>

    <!-- Desktop links -->
    <ul class="nav-links" id="nav-links">
      {navItems.map((item) => (
        <li class="nav-item">
          <a
            href={item.href}
            class={`nav-link ${isActive(item.href, currentPath) ? 'active' : ''}`}
            aria-current={isActive(item.href, currentPath) ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="nav-item nav-dropdown">
        <details class="nav-dropdown-details" open={isDataResourcesActive(currentPath) ? true : undefined}>
          <summary class={`nav-link nav-summary ${isDataResourcesActive(currentPath) ? 'active' : ''}`}>
            Data Resources
          </summary>
          <div class="nav-dropdown-panel" aria-label="Data resources menu">
            {dataResourcesItems.map((item) => (
              <a href={item.href} class="nav-dropdown-link">
                {item.label}
              </a>
            ))}
          </div>
        </details>
      </li>
    </ul>

    <!-- CTA + hamburger -->
    <div class="nav-actions">
      <a href={submitHref} class="nav-cta">Submit Resource</a>
      <button
        class="mobile-menu-button"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        id="mobile-menu-button"
      >
        <span class="hb"></span>
        <span class="hb"></span>
        <span class="hb"></span>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
    <ul class="mobile-links">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class={`mobile-link ${isActive(item.href, currentPath) ? 'active' : ''}`}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="mobile-dropdown">
        <details class="mobile-dropdown-details" open={isDataResourcesActive(currentPath) ? true : undefined}>
          <summary class={`mobile-link mobile-summary ${isDataResourcesActive(currentPath) ? 'active' : ''}`}>
            Data Resources
          </summary>
          <div class="mobile-dropdown-panel">
            {dataResourcesItems.map((item) => (
              <a href={item.href} class="mobile-link mobile-dropdown-link">
                {item.label}
              </a>
            ))}
          </div>
        </details>
      </li>
      <li><a href={submitHref} class="mobile-link mobile-link-cta">Submit a Resource →</a></li>
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-button');
  const drawer = document.getElementById('mobile-drawer');

  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    btn.classList.toggle('open', !open);
    drawer?.classList.toggle('open', !open);
    drawer?.setAttribute('aria-hidden', String(open));
  });

  document.addEventListener('click', (e) => {
    if (!(e.target instanceof Element)) return;
    if (!e.target.closest('.navbar')) {
      btn?.setAttribute('aria-expanded', 'false');
      btn?.classList.remove('open');
      drawer?.classList.remove('open');
      drawer?.setAttribute('aria-hidden', 'true');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      btn?.setAttribute('aria-expanded', 'false');
      btn?.classList.remove('open');
      drawer?.classList.remove('open');
      drawer?.setAttribute('aria-hidden', 'true');
    }
  });
</script>

<style>
  /* ── Navbar shell ─────────────────────────────── */
  .navbar {
    background: rgba(245, 248, 250, 0.92);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 1000;
    backdrop-filter: blur(16px) saturate(160%);
    -webkit-backdrop-filter: blur(16px) saturate(160%);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-6);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    height: 64px;
  }

  /* ── Brand ────────────────────────────────────── */
  .nav-brand { flex-shrink: 0; }

  .brand-link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .brand-link:hover { opacity: 0.8; text-decoration: none; }

  .brand-mark {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.1rem;
    letter-spacing: -0.04em;
    color: #F8FAFC;
    background: var(--color-primary);
    padding: 0.2em 0.45em 0.18em;
    border-radius: var(--radius-sm);
    line-height: 1;
    flex-shrink: 0;
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  /* ── Desktop nav links ────────────────────────── */
  .nav-links {
    display: none;
    list-style: none;
    gap: var(--space-1);
    margin: 0;
    padding: 0;
  }

  @media (min-width: 768px) {
    .nav-links { display: flex; }
  }

  .nav-item { margin: 0; }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-details {
    position: relative;
  }

  .nav-summary {
    list-style: none;
    cursor: pointer;
    padding-right: calc(var(--space-3) + 1rem);
  }

  .nav-summary::-webkit-details-marker {
    display: none;
  }

  .nav-summary::after {
    content: '▾';
    position: absolute;
    right: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.7em;
    color: currentColor;
    opacity: 0.8;
  }

  .nav-dropdown-details[open] .nav-summary::after {
    content: '▴';
  }

  .nav-dropdown-panel {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    min-width: 15rem;
    padding: var(--space-2);
    background: rgba(255, 255, 255, 0.98);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    z-index: 10;
  }

  .nav-dropdown-details[open] .nav-dropdown-panel,
  .nav-dropdown-details:hover .nav-dropdown-panel,
  .nav-dropdown-details:focus-within .nav-dropdown-panel {
    display: grid;
    gap: var(--space-1);
  }

  .nav-dropdown-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--font-size-sm);
    font-weight: 500;
    white-space: nowrap;
  }

  .nav-dropdown-link:hover {
    background: var(--color-primary-glow);
    color: var(--color-primary);
    text-decoration: none;
  }

  .nav-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
    white-space: nowrap;
    position: relative;
  }

  .nav-link:hover {
    background: var(--color-primary-glow);
    color: var(--color-primary);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--color-primary);
    font-weight: 600;
    background: var(--color-primary-glow);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: var(--space-3);
    right: var(--space-3);
    height: 2px;
    background: var(--color-primary);
    border-radius: 1px;
  }

  /* ── Nav actions ──────────────────────────────── */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .nav-cta {
    display: none;
    padding: var(--space-2) var(--space-4);
    background: var(--color-primary);
    color: #F8FAFC;
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.18s ease;
    white-space: nowrap;
    border: 1.5px solid var(--color-primary);
  }

  .nav-cta:hover {
    background: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
    box-shadow: var(--shadow-glow-primary);
    transform: translateY(-1px);
    text-decoration: none;
    color: #F8FAFC;
  }

  @media (min-width: 640px) {
    .nav-cta { display: inline-flex; align-items: center; }
  }

  /* ── Hamburger ────────────────────────────────── */
  .mobile-menu-button {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 38px;
    height: 38px;
    background: transparent;
    border: 1.5px solid var(--color-border);
    cursor: pointer;
    border-radius: var(--radius-md);
    transition: border-color 0.15s ease, background 0.15s ease;
    padding: 0;
    flex-shrink: 0;
  }

  .mobile-menu-button:hover {
    background: var(--color-primary-glow);
    border-color: var(--color-primary);
    box-shadow: none;
    transform: none;
  }

  .hb {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--color-text-muted);
    border-radius: 2px;
    transition: all 0.22s ease;
    transform-origin: center;
  }

  .mobile-menu-button.open .hb:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
    background: var(--color-primary);
  }
  .mobile-menu-button.open .hb:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .mobile-menu-button.open .hb:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
    background: var(--color-primary);
  }

  @media (min-width: 768px) {
    .mobile-menu-button { display: none; }
  }

  /* ── Mobile drawer ────────────────────────────── */
  .mobile-drawer {
    display: none;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4) var(--space-6);
    box-shadow: var(--shadow-md);
  }

  .mobile-drawer.open {
    display: block;
  }

  @media (min-width: 768px) {
    .mobile-drawer { display: none !important; }
  }

  .mobile-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-1);
  }

  .mobile-dropdown-details {
    display: grid;
    gap: var(--space-1);
  }

  .mobile-summary {
    list-style: none;
    cursor: pointer;
    position: relative;
    padding-right: calc(var(--space-4) + 1rem);
  }

  .mobile-summary::-webkit-details-marker {
    display: none;
  }

  .mobile-summary::after {
    content: '▾';
    position: absolute;
    right: var(--space-4);
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.75em;
    color: currentColor;
    opacity: 0.8;
  }

  .mobile-dropdown-details[open] .mobile-summary::after {
    content: '▴';
  }

  .mobile-dropdown-panel {
    display: grid;
    gap: var(--space-1);
    padding-left: var(--space-3);
  }

  .mobile-dropdown-link {
    margin-left: var(--space-2);
    font-size: var(--font-size-sm);
  }

  .mobile-link {
    display: block;
    padding: var(--space-3) var(--space-4);
    font-size: var(--font-size-base);
    font-weight: 500;
    color: var(--color-text-muted);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .mobile-link:hover {
    background: var(--color-primary-glow);
    color: var(--color-primary);
    text-decoration: none;
  }

  .mobile-link.active {
    color: var(--color-primary);
    font-weight: 600;
    background: var(--color-primary-glow);
  }

  .mobile-link-cta {
    color: var(--color-primary);
    font-weight: 700;
    border: 1.5px solid var(--color-border);
    text-align: center;
    margin-top: var(--space-2);
  }

  .mobile-link-cta:hover {
    background: var(--color-primary);
    color: #F8FAFC;
    border-color: var(--color-primary);
  }
</style>

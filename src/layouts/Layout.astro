---
import Navigation from '@components/Navigation.astro';
import '../styles/tailwind.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Community Data Libraries',
  description = 'A curated collection of data science resources and community-submitted materials for researchers, students, and practitioners.',
} = Astro.props;

const siteTitle =
  title === 'Community Data Libraries' ? title : `${title} | Community Data Libraries`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="icon" type="image/svg+xml" href="/web/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Fraunces: expressive serif for display — Outfit: clean geometric sans for body — JetBrains Mono -->
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,900;1,9..144,400;1,9..144,700&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{siteTitle}</title>
    <slot name="head" />
  </head>
  <body>
    <!-- Paper texture overlay -->
    <div class="paper-grain" aria-hidden="true"></div>
    <Navigation />
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-brand">
            <div class="footer-mark">CDL</div>
            <div>
              <span class="footer-title">Community Data Libraries</span>
              <p class="footer-tagline">Open-source data science resources for K–12 schools and communities.</p>
            </div>
          </div>
          <nav class="footer-links" aria-label="Footer navigation">
            <a href="/web/master-library">Master Library</a>
            <a href="/web/community-library">Community Library</a>
            <a href="/web/maps">Map</a>
            <a href="/web/submit">Submit</a>
            <a href="https://github.com/community-data-libraries/web" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
          </nav>
        </div>
        <div class="footer-bottom">
          <p class="footer-copy">&copy; {new Date().getFullYear()} Community Data Libraries. Open source under MIT.</p>
          <p class="footer-tagline-bottom">Built with Astro · Hosted on Netlify</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* =============================================
     CSS Reset
  ============================================= */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* =============================================
     Design System — Warm Archival
  ============================================= */
  :root {
    /* Warm parchment palette */
    --color-background: #F9F5EE;
    --color-surface: #FFFFFF;
    --color-surface-raised: #F2EDE4;
    --color-border: #DDD5C4;
    --color-border-highlight: #C4B49E;

    /* Brand — Burnt Sienna / Terracotta */
    --color-primary: #C2410C;
    --color-primary-dark: #9A3412;
    --color-primary-light: #EA580C;
    --color-primary-glow: rgba(194, 65, 12, 0.10);

    /* Secondary — Deep Forest Green (complement) */
    --color-secondary: #166534;
    --color-secondary-light: #16a34a;
    --color-secondary-glow: rgba(22, 101, 52, 0.10);

    /* Accent — Amber Gold */
    --color-accent: #B45309;
    --color-accent-light: #D97706;
    --color-accent-glow: rgba(180, 83, 9, 0.10);

    /* Text — warm blacks & browns */
    --color-text: #1C130C;
    --color-text-muted: #6B5541;
    --color-text-dim: #A8927A;

    /* Typography */
    --font-display: 'Fraunces', Georgia, 'Times New Roman', serif;
    --font-sans: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'JetBrains Mono', 'SF Mono', Monaco, 'Cascadia Code', monospace;

    --font-size-xs: 0.75rem;
    --font-size-sm: 0.875rem;
    --font-size-base: 1rem;
    --font-size-lg: 1.125rem;
    --font-size-xl: 1.25rem;
    --font-size-2xl: 1.5rem;
    --font-size-3xl: 1.875rem;
    --font-size-4xl: 2.25rem;

    --line-height-tight: 1.2;
    --line-height-normal: 1.6;
    --line-height-relaxed: 1.8;

    /* Spacing */
    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-5: 1.25rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-12: 3rem;
    --space-16: 4rem;
    --space-24: 6rem;

    /* Shadows — warm-toned */
    --shadow-sm: 0 1px 3px 0 rgba(100, 60, 20, 0.10);
    --shadow-md: 0 4px 16px -2px rgba(100, 60, 20, 0.14);
    --shadow-lg: 0 12px 40px -8px rgba(100, 60, 20, 0.18);
    --shadow-glow-primary: 0 4px 20px -4px rgba(194, 65, 12, 0.28);
    --shadow-glow-secondary: 0 4px 20px -4px rgba(22, 101, 52, 0.25);
    --shadow-glow-accent: 0 4px 20px -4px rgba(180, 83, 9, 0.28);

    /* Radii */
    --radius-sm: 0.2rem;
    --radius-md: 0.45rem;
    --radius-lg: 0.875rem;
    --radius-xl: 1.5rem;
  }

  /* =============================================
     Paper grain texture
  ============================================= */
  .paper-grain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 9999;
    opacity: 0.028;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 128px 128px;
  }

  /* =============================================
     Base
  ============================================= */
  html {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: var(--line-height-normal);
    color: var(--color-text);
    background-color: var(--color-background);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-color: var(--color-background);
    /* Subtle warm vignette */
    background-image:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(194, 65, 12, 0.04) 0%, transparent 70%),
      radial-gradient(ellipse 60% 40% at 100% 20%, rgba(180, 83, 9, 0.03) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 0% 80%, rgba(22, 101, 52, 0.03) 0%, transparent 60%);
  }

  main {
    flex: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
  }

  /* =============================================
     Typography
  ============================================= */
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-display);
    font-weight: 700;
    line-height: var(--line-height-tight);
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  h1 { font-size: var(--font-size-4xl); font-weight: 900; }
  h2 { font-size: var(--font-size-3xl); }
  h3 { font-size: var(--font-size-2xl); }
  h4 { font-size: var(--font-size-xl); }

  p { margin-bottom: var(--space-4); }

  a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.18s ease;
  }

  a:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  ul, ol {
    margin-left: var(--space-6);
    margin-bottom: var(--space-4);
  }

  code {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    background-color: var(--color-surface-raised);
    color: var(--color-primary);
    padding: 0.12em var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    h1 { font-size: var(--font-size-3xl); }
    h2 { font-size: var(--font-size-2xl); }
    h3 { font-size: var(--font-size-xl); }
  }

  /* =============================================
     Buttons
  ============================================= */
  button, .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background-color: var(--color-primary);
    color: #FFF8F4;
    border: 1.5px solid var(--color-primary);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: all 0.18s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  button:hover, .button:hover {
    background-color: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
    box-shadow: var(--shadow-glow-primary);
    transform: translateY(-1px);
    text-decoration: none;
    color: #FFF8F4;
  }

  /* =============================================
     Footer
  ============================================= */
  footer {
    background-color: var(--color-text);
    color: #D6C9B8;
    padding: var(--space-12) var(--space-6) var(--space-8);
    margin-top: var(--space-16);
    position: relative;
    overflow: hidden;
  }

  /* Decorative top border stripe */
  footer::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary) 0%, var(--color-accent-light) 50%, var(--color-secondary-light) 100%);
  }

  /* Decorative large CDL watermark */
  footer::after {
    content: 'CDL';
    position: absolute;
    right: -0.02em;
    bottom: -0.15em;
    font-family: var(--font-display);
    font-size: 18rem;
    font-weight: 900;
    color: rgba(255,255,255,0.03);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.05em;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-8);
    flex-wrap: wrap;
    padding-bottom: var(--space-8);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: var(--space-6);
  }

  .footer-brand {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .footer-mark {
    font-family: var(--font-display);
    font-size: var(--font-size-xl);
    font-weight: 900;
    color: var(--color-primary-light);
    letter-spacing: -0.04em;
    line-height: 1;
    padding: var(--space-2) var(--space-3);
    border: 1.5px solid rgba(194, 65, 12, 0.4);
    border-radius: var(--radius-sm);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .footer-title {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--font-size-lg);
    color: #F5EFE8;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-1);
  }

  .footer-tagline {
    margin: 0;
    font-size: var(--font-size-sm);
    color: #8A7A6A;
    line-height: var(--line-height-relaxed);
    max-width: 30ch;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    align-items: center;
  }

  .footer-links a {
    font-size: var(--font-size-sm);
    color: #8A7A6A;
    text-decoration: none;
    transition: color 0.15s ease;
    font-weight: 500;
  }

  .footer-links a:hover {
    color: var(--color-primary-light);
    text-decoration: none;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: var(--font-size-xs);
    color: #5A4A3A;
    margin: 0;
    font-family: var(--font-mono);
  }

  .footer-tagline-bottom {
    font-size: var(--font-size-xs);
    color: #5A4A3A;
    margin: 0;
    font-family: var(--font-mono);
  }

  /* =============================================
     Accessibility
  ============================================= */
  :focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .skip-to-main {
    position: absolute;
    left: -9999px;
    z-index: 999;
  }

  .skip-to-main:focus {
    left: 50%;
    transform: translateX(-50%);
    top: var(--space-4);
  }

  /* =============================================
     Global scroll animation utility
  ============================================= */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>

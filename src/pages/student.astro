---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { extractThemes } from '@lib/data/libraryAccess';
import { withBasePath } from '@lib/paths';

const resources = await getCollection('master-library');
const dataThemes = extractThemes(resources, 'student');
---

<Layout
  title="Student"
  description="Learning resources and tools for students building data skills and projects."
>
  <section class="role-shell">
    <header class="role-header">
      <div class="role-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
          <path d="M6 12v5c3 3 9 3 12 0v-5"/>
        </svg>
      </div>
      <div>
        <h1>Student View</h1>
        <p class="role-desc">
          Beginner-friendly tools, datasets, and guides for coursework, capstones, and portfolio projects.
        </p>
      </div>
    </header>

    <a href={withBasePath('/complete-catalog?audience=student')} class="button cta-button">Open Complete Catalog as Student &rarr;</a>

    <article class="panel">
      <h2>Available Data Themes</h2>
      {dataThemes.length > 0 ? (
        <ul>
          {dataThemes.map((theme) => (
            <li>{theme}</li>
          ))}
        </ul>
      ) : (
        <p class="empty-note">No themes available yet.</p>
      )}
    </article>

    <div class="info-card">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <p>Some sensitive datasets are intentionally excluded from student view (for example, opioid addiction data themes). Ask your teacher for full access if needed.</p>
    </div>
  </section>

  <style>
    .role-shell {
      display: grid;
      gap: var(--space-6);
      max-width: 720px;
    }

    .role-header {
      display: flex;
      align-items: flex-start;
      gap: var(--space-4);
    }

    .role-icon {
      width: 52px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: color-mix(in srgb, var(--color-primary) 10%, var(--color-surface));
      border-radius: var(--radius-lg);
      color: var(--color-primary);
      flex-shrink: 0;
    }

    .role-header h1 {
      margin-bottom: var(--space-2);
    }

    .role-desc {
      color: var(--color-text-muted);
      font-size: var(--font-size-lg);
      margin: 0;
    }

    .cta-button {
      display: inline-flex;
      align-items: center;
      align-self: start;
    }

    .panel {
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
    }

    .panel h2 {
      margin-bottom: var(--space-4);
      font-size: var(--font-size-base);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-text-muted);
    }

    .panel ul {
      margin: 0;
      padding-left: 1.25rem;
      display: grid;
      gap: var(--space-2);
      font-size: var(--font-size-sm);
    }

    .empty-note {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
    }

    .info-card {
      display: flex;
      gap: var(--space-3);
      align-items: flex-start;
      padding: var(--space-4) var(--space-5);
      background: color-mix(in srgb, var(--color-primary) 6%, var(--color-surface));
      border: 1px solid color-mix(in srgb, var(--color-primary) 20%, var(--color-border));
      border-radius: var(--radius-lg);
      color: var(--color-primary);
    }

    .info-card svg {
      flex-shrink: 0;
      margin-top: 2px;
    }

    .info-card p {
      margin: 0;
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
      line-height: var(--line-height-relaxed);
    }
  </style>
</Layout>

---
import { withBasePath } from '@lib/paths';

const targetPath = withBasePath('/complete-catalog');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting to Complete Catalog</title>
    <meta http-equiv="refresh" content={`0; url=${targetPath}`} />
  </head>
  <body>
    <p>
      Redirecting to the
      <a href={targetPath}>Complete Catalog</a>...
    </p>
    <script is:inline>
      const target = `${targetPath}${window.location.search}`;
      window.location.replace(target);
    </script>
  </body>
</html>

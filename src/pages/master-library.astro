---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { audienceLabel, canAudienceAccess, type AudienceRole } from '@lib/data/libraryAccess';

const resources = await getCollection('master-library');
const rawAudience = Astro.url.searchParams.get('audience');
const audience: AudienceRole =
  rawAudience === 'teacher' || rawAudience === 'student' || rawAudience === 'community'
    ? rawAudience
    : 'community';

const visibleResources = resources.filter((resource) => canAudienceAccess(resource, audience));

const selectedCategory = (Astro.url.searchParams.get('category') ?? '').trim();
const selectedTag = (Astro.url.searchParams.get('tag') ?? '').trim();
const query = (Astro.url.searchParams.get('q') ?? '').trim();
const sort = Astro.url.searchParams.get('sort') ?? 'updated';

const searchQuery = query.toLowerCase();

const allThemes = Array.from(
  new Set(
    visibleResources.flatMap((resource) =>
      resource.data.dataThemes.length > 0 ? resource.data.dataThemes : resource.data.tags,
    ),
  ),
).sort((left, right) => left.localeCompare(right));

const allTags = Array.from(new Set(visibleResources.flatMap((resource) => resource.data.tags))).sort((left, right) =>
  left.localeCompare(right),
);

const filteredResources = visibleResources.filter((resource) => {
  const themes = resource.data.dataThemes.length > 0 ? resource.data.dataThemes : resource.data.tags;
  const matchesCategory = selectedCategory ? themes.includes(selectedCategory) : true;
  const matchesTag = selectedTag ? resource.data.tags.includes(selectedTag) : true;
  const haystack = [resource.data.title, resource.data.description, ...themes, ...resource.data.tags]
    .join(' ')
    .toLowerCase();
  const matchesSearch = searchQuery ? haystack.includes(searchQuery) : true;
  return matchesCategory && matchesTag && matchesSearch;
});

const sortedResources = [...filteredResources].sort((left, right) => {
  if (sort === 'title') {
    return left.data.title.localeCompare(right.data.title);
  }

  if (sort === 'featured') {
    return Number(right.data.featured) - Number(left.data.featured);
  }

  const leftTime = left.data.publishedDate ? new Date(left.data.publishedDate).getTime() : 0;
  const rightTime = right.data.publishedDate ? new Date(right.data.publishedDate).getTime() : 0;
  return rightTime - leftTime;
});

const featuredResources = sortedResources.filter((resource) => resource.data.featured).slice(0, 2);
const listResources = sortedResources.filter(
  (resource) => !featuredResources.some((featured) => featured.id === resource.id),
);

const typeCounts = visibleResources.reduce(
  (accumulator, resource) => {
    accumulator[resource.data.category] += 1;
    return accumulator;
  },
  {
    dataset: 0,
    tool: 0,
    guide: 0,
    paper: 0,
  },
);

const clearFiltersHref = `/web/master-library?audience=${audience}`;
const activeFilters = [
  selectedCategory ? `Theme: ${selectedCategory}` : '',
  selectedTag ? `Tag: ${selectedTag}` : '',
  query ? `Search: ${query}` : '',
].filter(Boolean);

function audienceHref(nextAudience: AudienceRole): string {
  const params = new URLSearchParams();
  params.set('audience', nextAudience);
  if (selectedCategory) params.set('category', selectedCategory);
  if (selectedTag) params.set('tag', selectedTag);
  if (query) params.set('q', query);
  if (sort) params.set('sort', sort);
  return `/web/master-library?${params.toString()}`;
}

function formatDate(date: Date | undefined): string {
  if (!date) return 'Not specified';
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title="Master Library" description="All curated resources in the CDL master library">
  <section class="library-page">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <h2>Filters</h2>
        <button class="sidebar-close" id="sidebar-close" aria-label="Close filters">✕</button>
      </div>
      <form method="get" action="/web/master-library" class="filters-form">
        <input type="hidden" name="audience" value={audience} />

        <label>
          <span>Search</span>
          <input type="search" name="q" value={query} placeholder="Search title, description, or themes" />
        </label>

        <label>
          <span>Theme</span>
          <select name="category">
            <option value="">All themes</option>
            {allThemes.map((theme) => (
              <option value={theme} selected={selectedCategory === theme}>{theme}</option>
            ))}
          </select>
        </label>

        <label>
          <span>Tag</span>
          <select name="tag">
            <option value="">All tags</option>
            {allTags.map((tag) => (
              <option value={tag} selected={selectedTag === tag}>{tag}</option>
            ))}
          </select>
        </label>

        <label>
          <span>Sort</span>
          <select name="sort">
            <option value="updated" selected={sort === 'updated'}>Most recent</option>
            <option value="featured" selected={sort === 'featured'}>Featured first</option>
            <option value="title" selected={sort === 'title'}>A-Z</option>
          </select>
        </label>

        <div class="filter-actions">
          <button type="submit" class="button">Apply</button>
          <a href={clearFiltersHref} class="reset-link">Reset</a>
        </div>
      </form>

      <section class="type-panel">
        <h3>Resource Types</h3>
        <ul>
          <li><span>Datasets</span><strong>{typeCounts.dataset}</strong></li>
          <li><span>Guides</span><strong>{typeCounts.guide}</strong></li>
          <li><span>Tools</span><strong>{typeCounts.tool}</strong></li>
          <li><span>Papers</span><strong>{typeCounts.paper}</strong></li>
        </ul>
      </section>
    </aside>

    <div class="content">
      <button class="mobile-filter-btn" id="mobile-filter-btn" aria-expanded="false" aria-controls="sidebar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
        Filters
      </button>
      <header class="content-header">
        <div>
          <h1>Master Library</h1>
          <p>
            Showing <strong>{audienceLabel(audience)}</strong> view.
            {audience !== 'teacher' && ' Sensitive datasets are excluded.'}
          </p>
        </div>
        <div class="audience-switch">
          <a href={audienceHref('teacher')} class={audience === 'teacher' ? 'active' : undefined}>Teacher</a>
          <a href={audienceHref('student')} class={audience === 'student' ? 'active' : undefined}>Student</a>
          <a href={audienceHref('community')} class={audience === 'community' ? 'active' : undefined}>Community</a>
        </div>
      </header>

      <div class="results-head">
        <p><strong>{sortedResources.length}</strong> resources</p>
        <div class="results-head-right">
          {activeFilters.length > 0 && <a href={clearFiltersHref}>Clear filters</a>}
          <div class="view-toggle" role="group" aria-label="View mode">
            <button class="view-btn active" data-view="list" title="List view" aria-pressed="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            </button>
            <button class="view-btn" data-view="grid" title="Grid view" aria-pressed="false">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            </button>
            <button class="view-btn" data-view="table" title="Table view" aria-pressed="false">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="9" x2="9" y2="21"/></svg>
            </button>
          </div>
        </div>
      </div>

      {activeFilters.length > 0 && (
        <div class="active-filters" aria-label="Active filters">
          {activeFilters.map((item) => (
            <span class="chip">{item}</span>
          ))}
        </div>
      )}

      {featuredResources.length > 0 && (
        <section class="featured">
          <h2>Featured</h2>
          <div class="featured-grid">
            {featuredResources.map((resource) => (
              <article class="featured-card">
                <h3>
                  {resource.data.url ? (
                    <a href={resource.data.url} target="_blank" rel="noopener noreferrer">{resource.data.title}</a>
                  ) : (
                    resource.data.title
                  )}
                </h3>
                <p>{resource.data.description}</p>
                <p class="meta-line">Updated {formatDate(resource.data.publishedDate)}</p>
              </article>
            ))}
          </div>
        </section>
      )}

      <section class="results" id="results-section" data-view="list">
        <h2>All Resources</h2>

        {listResources.length === 0 ? (
          <article class="result-card empty"><p>No resources match your current filter combination.</p></article>
        ) : (
          <>
            {/* Card / Grid view */}
            <div class="cards-view">
              {listResources.map((resource) => {
                const themes = resource.data.dataThemes.length > 0 ? resource.data.dataThemes : resource.data.tags;
                return (
                  <article class="result-card">
                    <div class="result-main">
                      <h3>
                        {resource.data.url ? (
                          <a href={resource.data.url} target="_blank" rel="noopener noreferrer">{resource.data.title}</a>
                        ) : (
                          resource.data.title
                        )}
                      </h3>
                      <p>{resource.data.description}</p>
                      <div class="chips">
                        <span class="chip">{resource.data.category}</span>
                        {themes.slice(0, 3).map((theme) => (
                          <span class="chip">{theme}</span>
                        ))}
                        {audience === 'teacher' && resource.data.pedagogicalTags.slice(0, 2).map((tag) => (
                          <span class="chip chip-accent">{tag}</span>
                        ))}
                      </div>
                    </div>
                    <aside class="result-side">
                      <p><strong>Updated</strong></p>
                      <p>{formatDate(resource.data.publishedDate)}</p>
                      <p><strong>Difficulty</strong></p>
                      <p>{resource.data.difficulty ?? 'Not specified'}</p>
                    </aside>
                  </article>
                );
              })}
            </div>

            {/* Table view */}
            <div class="table-view">
              <table>
                <thead>
                  <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Themes</th>
                    {audience === 'teacher' && <th>Pedagogical Tags</th>}
                    <th>Difficulty</th>
                    <th>Updated</th>
                  </tr>
                </thead>
                <tbody>
                  {listResources.map((resource) => {
                    const themes = resource.data.dataThemes.length > 0 ? resource.data.dataThemes : resource.data.tags;
                    return (
                      <tr>
                        <td class="td-title">
                          {resource.data.url ? (
                            <a href={resource.data.url} target="_blank" rel="noopener noreferrer">{resource.data.title}</a>
                          ) : (
                            resource.data.title
                          )}
                        </td>
                        <td><span class="chip">{resource.data.category}</span></td>
                        <td>
                          <div class="chips">
                            {themes.slice(0, 2).map((theme) => (
                              <span class="chip">{theme}</span>
                            ))}
                          </div>
                        </td>
                        {audience === 'teacher' && (
                          <td>
                            <div class="chips">
                              {resource.data.pedagogicalTags.slice(0, 2).map((tag) => (
                                <span class="chip chip-accent">{tag}</span>
                              ))}
                            </div>
                          </td>
                        )}
                        <td class="td-meta">{resource.data.difficulty ?? '—'}</td>
                        <td class="td-meta">{formatDate(resource.data.publishedDate)}</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </>
        )}
      </section>
    </div>
  </section>

  <script>
    // Mobile sidebar toggle
    const mobileFilterBtn = document.getElementById('mobile-filter-btn');
    const sidebarEl = document.getElementById('sidebar');
    const sidebarClose = document.getElementById('sidebar-close');

    function openSidebar() {
      sidebarEl?.classList.add('open');
      mobileFilterBtn?.setAttribute('aria-expanded', 'true');
    }
    function closeSidebar() {
      sidebarEl?.classList.remove('open');
      mobileFilterBtn?.setAttribute('aria-expanded', 'false');
    }

    mobileFilterBtn?.addEventListener('click', openSidebar);
    sidebarClose?.addEventListener('click', closeSidebar);

    // View toggle
    const section = document.getElementById('results-section');
    const buttons = document.querySelectorAll('.view-btn');

    const saved = localStorage.getItem('ml-view') ?? 'list';
    applyView(saved);

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const view = (btn as HTMLElement).dataset.view ?? 'list';
        applyView(view);
        localStorage.setItem('ml-view', view);
      });
    });

    function applyView(view: string) {
      if (!section) return;
      section.dataset.view = view;
      buttons.forEach((btn) => {
        const isActive = (btn as HTMLElement).dataset.view === view;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', String(isActive));
      });
    }
  </script>

  <style>
    /* ── Layout ─────────────────────────── */
    .library-page {
      display: grid;
      gap: var(--space-6);
      grid-template-columns: 1fr;
    }

    @media (min-width: 1024px) {
      .library-page {
        grid-template-columns: minmax(260px, 290px) 1fr;
        align-items: start;
      }
    }

    /* ── Mobile filter toggle ─────────── */
    .mobile-filter-btn {
      display: none;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-2) var(--space-4);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 999px;
      font-size: var(--font-size-sm);
      font-weight: 600;
      color: var(--color-text-muted);
      cursor: pointer;
      margin-bottom: var(--space-4);
      transition: all 0.15s ease;
    }

    .mobile-filter-btn:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
      background: var(--color-primary-glow);
      box-shadow: none;
      transform: none;
    }

    .sidebar-close {
      display: none;
      background: none;
      border: 1px solid var(--color-border);
      cursor: pointer;
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
      padding: var(--space-1) var(--space-3);
      border-radius: var(--radius-md);
      transition: all 0.15s ease;
      transform: none;
    }

    .sidebar-close:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
      box-shadow: none;
    }

    /* ── Sidebar ─────────────────────── */
    .sidebar-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .sidebar {
      position: sticky;
      top: calc(60px + var(--space-8));
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-surface);
      padding: var(--space-5);
      display: grid;
      gap: var(--space-5);
    }

    @media (max-width: 1023px) {
      .mobile-filter-btn { display: inline-flex; }
      .sidebar-close { display: inline-flex; align-items: center; }

      .sidebar {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        z-index: 200;
        border-radius: 0;
        overflow-y: auto;
        border: none;
        padding-top: var(--space-8);
      }

      .sidebar.open { display: grid; }
    }

    .sidebar h2 {
      margin: 0;
      font-size: var(--font-size-lg);
      color: var(--color-text);
    }

    .filters-form {
      display: grid;
      gap: var(--space-4);
    }

    .filters-form label {
      display: grid;
      gap: var(--space-2);
    }

    .filters-form span {
      font-size: var(--font-size-xs);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--color-text-dim);
    }

    .filters-form input,
    .filters-form select {
      width: 100%;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-2) var(--space-3);
      background: var(--color-surface-raised);
      color: var(--color-text);
      font-family: var(--font-sans);
      font-size: var(--font-size-sm);
      transition: border-color 0.15s ease;
      appearance: none;
      -webkit-appearance: none;
    }

    .filters-form input:focus,
    .filters-form select:focus {
      outline: none;
      border-color: var(--color-primary);
    }

    .filter-actions {
      display: flex;
      align-items: center;
      gap: var(--space-3);
    }

    .filter-actions .button {
      padding: var(--space-2) var(--space-4);
      font-size: var(--font-size-sm);
      border-radius: var(--radius-md);
    }

    .reset-link {
      display: inline-flex;
      align-items: center;
      padding: var(--space-2) var(--space-3);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
      font-weight: 500;
      text-decoration: none;
      transition: all 0.15s ease;
    }

    .reset-link:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
      background: var(--color-primary-glow);
      text-decoration: none;
    }

    .type-panel {
      border-top: 1px solid var(--color-border);
      padding-top: var(--space-4);
    }

    .type-panel h3 {
      margin: 0 0 var(--space-3);
      font-size: var(--font-size-xs);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--color-text-dim);
    }

    .type-panel ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: var(--space-2);
    }

    .type-panel li {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
    }

    .type-panel li strong {
      font-family: var(--font-mono);
      font-size: var(--font-size-xs);
      color: var(--color-primary);
    }

    /* ── Content area ────────────────── */
    .content {
      display: grid;
      gap: var(--space-5);
    }

    .content-header {
      display: grid;
      gap: var(--space-4);
    }

    .content-header h1 {
      margin-bottom: var(--space-2);
      font-size: clamp(var(--font-size-2xl), 2.5vw, var(--font-size-4xl));
    }

    .content-header p {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
    }

    .audience-switch {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .audience-switch a {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-2) var(--space-4);
      font-size: var(--font-size-sm);
      font-weight: 500;
      color: var(--color-text-muted);
      text-decoration: none;
      transition: all 0.15s ease;
      background: transparent;
    }

    .audience-switch a:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
      background: var(--color-primary-glow);
      text-decoration: none;
    }

    .audience-switch a.active {
      background: var(--color-primary);
      border-color: var(--color-primary);
      color: #03160e;
      font-weight: 600;
    }

    .audience-switch a.active:hover {
      background: var(--color-primary-dark);
      border-color: var(--color-primary-dark);
      color: #03160e;
    }

    /* ── Results head ────────────────── */
    .results-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-3) 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
    }

    .results-head p { margin: 0; }
    .results-head strong { color: var(--color-text); }

    .results-head-right {
      display: flex;
      align-items: center;
      gap: var(--space-4);
    }

    /* View toggle */
    .view-toggle {
      display: flex;
      gap: 2px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: 3px;
      background: var(--color-surface-raised);
    }

    .view-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 34px;
      border: none;
      border-radius: calc(var(--radius-md) - 2px);
      background: transparent;
      color: var(--color-text-dim);
      cursor: pointer;
      transition: background 0.15s ease, color 0.15s ease;
      padding: 0;
    }

    .view-btn:hover {
      background: var(--color-primary-glow);
      color: var(--color-primary);
      box-shadow: none;
      transform: none;
    }

    .view-btn.active {
      background: var(--color-primary);
      color: #03160e;
    }

    /* ── Active filters ───────────────── */
    .active-filters {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
      margin-top: calc(var(--space-3) * -1);
    }

    /* ── Featured + Results ──────────── */
    .featured, .results {
      display: grid;
      gap: var(--space-3);
    }

    .featured h2, .results h2 {
      margin: 0;
      font-size: var(--font-size-base);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--color-text-dim);
    }

    .featured-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    @media (min-width: 900px) {
      .featured-grid { grid-template-columns: 1fr 1fr; }
    }

    .featured-card, .result-card {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-surface);
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }

    .featured-card:hover, .result-card:hover {
      border-color: var(--color-border-highlight);
    }

    .featured-card {
      padding: var(--space-5);
      display: grid;
      gap: var(--space-3);
    }

    .featured-card h3, .result-main h3 {
      margin: 0;
      font-size: var(--font-size-lg);
      letter-spacing: -0.02em;
    }

    .featured-card h3 a, .result-main h3 a {
      color: var(--color-text);
      transition: color 0.15s ease;
    }

    .featured-card h3 a:hover, .result-main h3 a:hover {
      color: var(--color-primary);
      text-decoration: none;
    }

    .featured-card p { margin: 0; color: var(--color-text-muted); font-size: var(--font-size-sm); }

    .meta-line {
      color: var(--color-text-dim);
      font-family: var(--font-mono);
      font-size: var(--font-size-xs);
    }

    /* ── Cards ─────────────────────────── */
    .result-card { display: grid; grid-template-columns: 1fr; }

    .result-main {
      padding: var(--space-5);
      display: grid;
      gap: var(--space-3);
    }

    .result-main p {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
      line-height: var(--line-height-relaxed);
    }

    /* ── Chips ─────────────────────────── */
    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .chip {
      display: inline-flex;
      align-items: center;
      padding: 2px var(--space-2);
      border-radius: var(--radius-sm);
      border: 1px solid var(--color-border);
      font-size: var(--font-size-xs);
      font-weight: 500;
      color: var(--color-text-muted);
      background: var(--color-surface-raised);
    }

    .chip-accent {
      border-color: rgba(16, 185, 129, 0.3);
      color: var(--color-primary);
      background: var(--color-primary-glow);
    }

    /* ── Result sidebar meta ─────────── */
    .result-side {
      border-top: 1px solid var(--color-border);
      padding: var(--space-5);
      font-size: var(--font-size-xs);
      color: var(--color-text-dim);
      background: var(--color-surface-raised);
      border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    }

    .result-side p {
      margin: 0 0 var(--space-2);
      line-height: var(--line-height-normal);
    }

    .result-side strong {
      display: block;
      font-size: var(--font-size-xs);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--color-text-dim);
      margin-bottom: var(--space-1);
    }

    .result-card.empty { padding: var(--space-8); text-align: center; }
    .result-card.empty p { margin: 0; color: var(--color-text-dim); }

    /* ── View logic ───────────────────── */
    .cards-view { display: grid; gap: var(--space-3); }
    .table-view { display: none; }

    /* List view */
    #results-section[data-view="list"] .cards-view { display: grid; }
    #results-section[data-view="list"] .result-card { grid-template-columns: 1fr; }

    @media (min-width: 900px) {
      #results-section[data-view="list"] .result-card {
        grid-template-columns: minmax(0, 1fr) 200px;
      }
      #results-section[data-view="list"] .result-side {
        border-top: none;
        border-left: 1px solid var(--color-border);
        border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
      }
    }

    /* Grid view */
    #results-section[data-view="grid"] .cards-view {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    @media (min-width: 640px) {
      #results-section[data-view="grid"] .cards-view {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    #results-section[data-view="grid"] .result-card {
      grid-template-columns: 1fr;
      display: flex;
      flex-direction: column;
    }

    #results-section[data-view="grid"] .result-side { display: none; }
    #results-section[data-view="grid"] .result-main { flex: 1; }

    /* Table view */
    #results-section[data-view="table"] .cards-view { display: none; }

    #results-section[data-view="table"] .table-view {
      display: block;
      overflow-x: auto;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-surface);
    }

    .table-view table {
      width: 100%;
      border-collapse: collapse;
      font-size: var(--font-size-sm);
    }

    .table-view thead {
      background: var(--color-surface-raised);
      border-bottom: 1px solid var(--color-border);
    }

    .table-view th {
      text-align: left;
      padding: var(--space-3) var(--space-4);
      font-size: var(--font-size-xs);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--color-text-dim);
      white-space: nowrap;
    }

    .table-view td {
      padding: var(--space-3) var(--space-4);
      border-bottom: 1px solid var(--color-border);
      vertical-align: middle;
    }

    .table-view tbody tr:last-child td { border-bottom: none; }

    .table-view tbody tr:hover {
      background: var(--color-primary-glow);
    }

    .td-title { font-weight: 600; color: var(--color-text); min-width: 200px; }
    .td-title a { color: var(--color-text); transition: color 0.15s ease; }
    .td-title a:hover { color: var(--color-primary); text-decoration: none; }
    .td-meta { color: var(--color-text-dim); white-space: nowrap; font-family: var(--font-mono); font-size: var(--font-size-xs); }
  </style>
</Layout>

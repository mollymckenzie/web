---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title="Home"
  description="Discover curated data science resources and contribute to our growing community library of datasets, tools, guides, and research papers."
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <h1 class="hero-title">
        <span class="gradient-text">Community Data Libraries</span>
      </h1>
      <p class="hero-description">
        Curated datasets, tools, guides, and research papers — for researchers,
        students, and communities.
      </p>
      <div class="hero-actions">
        <a href="/web/master-library" class="button">Explore the Library</a>
        <a href="/web/maps" class="button button-ghost">View Map</a>
      </div>
    </div>
  </section>

  <!-- Audience quick-links -->
  <section class="audience-bar" aria-label="Browse by role">
    <span class="audience-label">Browse as:</span>
    <div class="audience-pills">
      <a href="/web/teacher" class="pill">Teacher</a>
      <a href="/web/student" class="pill">Student</a>
      <a href="/web/community-member" class="pill">Community Member</a>
    </div>
  </section>

  <!-- Feature cards -->
  <section class="features" aria-label="Key sections">
    <div class="feature-grid">
      <article class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </div>
        <h2>Master Library</h2>
        <p>
          Expert-curated datasets, tools, guides, and research papers, organized by theme and audience.
        </p>
        <a href="/web/master-library" class="feature-link">Explore resources &rarr;</a>
      </article>

      <article class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <h2>Community Library</h2>
        <p>
          Resources contributed by practitioners from around the world. Unique datasets and local knowledge.
        </p>
        <a href="/web/community-library" class="feature-link">Browse community &rarr;</a>
      </article>

      <article class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </div>
        <h2>Contribute</h2>
        <p>
          Share datasets, tools, or guides with the community. Help others discover valuable resources.
        </p>
        <a href="/web/submit" class="feature-link">Submit a resource &rarr;</a>
      </article>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-section" aria-label="Platform statistics">
    <div class="stats-grid">
      <div class="stat-item">
        <span class="stat-number">500+</span>
        <span class="stat-label">Curated Resources</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-item">
        <span class="stat-number">1,000+</span>
        <span class="stat-label">Community Submissions</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-item">
        <span class="stat-number">10k+</span>
        <span class="stat-label">Active Users</span>
      </div>
      <div class="stat-divider" aria-hidden="true"></div>
      <div class="stat-item">
        <span class="stat-number">100%</span>
        <span class="stat-label">Open Source</span>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: var(--space-16) var(--space-4) var(--space-12);
    text-align: center;
  }

  .hero-inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-6);
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-description {
    font-size: var(--font-size-xl);
    color: var(--color-text-muted);
    line-height: var(--line-height-relaxed);
    margin-bottom: var(--space-8);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  .button-ghost {
    background-color: transparent;
    color: var(--color-primary);
    border: 1.5px solid var(--color-primary);
  }

  .button-ghost:hover {
    background-color: var(--color-primary);
    color: white;
  }

  /* Audience bar */
  .audience-bar {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-12);
    flex-wrap: wrap;
  }

  .audience-label {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .audience-pills {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    transition: all 0.15s ease;
    background: var(--color-background);
  }

  .pill:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 6%, var(--color-surface));
    text-decoration: none;
  }

  /* Feature grid */
  .features {
    margin-bottom: var(--space-12);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 640px) {
    .feature-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    display: grid;
    gap: var(--space-3);
    align-content: start;
    transition:
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .feature-card:hover {
    box-shadow: var(--shadow-md);
    border-color: color-mix(in srgb, var(--color-primary) 40%, var(--color-border));
  }

  .feature-icon-wrap {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--color-primary) 10%, var(--color-surface));
    border-radius: var(--radius-md);
    color: var(--color-primary);
  }

  .feature-card h2 {
    font-size: var(--font-size-xl);
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .feature-card p {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    line-height: var(--line-height-relaxed);
    margin: 0;
  }

  .feature-link {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    margin-top: var(--space-2);
  }

  .feature-link:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
  }

  /* Stats */
  .stats-section {
    margin-bottom: var(--space-8);
  }

  .stats-grid {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-6) var(--space-8);
    flex: 1;
    min-width: 120px;
    gap: var(--space-1);
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .stats-grid {
      flex-direction: column;
    }

    .stat-divider {
      width: 80%;
      height: 1px;
    }
  }

  .stat-number {
    font-size: var(--font-size-3xl);
    font-weight: 800;
    color: var(--color-primary);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    text-align: center;
  }
</style>

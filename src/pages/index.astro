---
import Layout from '@layouts/Layout.astro';
---

<Layout
  title="Home"
  description="Discover curated data science resources and contribute to our growing community library of datasets, tools, guides, and research papers."
>
  <!-- ═══════════════════════════════════════════
       HERO — Split layout: text left, visual right
  ═══════════════════════════════════════════ -->
  <section class="hero" aria-label="Introduction">
    <div class="hero-text">
      <div class="hero-kicker">
        <span class="kicker-dot"></span>
        Open-Source · K–12 Focused · Free Forever
      </div>

      <h1 class="hero-title">
        Where<br/>
        <em>communities</em><br/>
        find their data.
      </h1>

      <p class="hero-body">
        A curated catalog of datasets, tools, guides, and research papers —
        filtered to your geography, organized for teachers and students.
      </p>

      <div class="hero-actions">
        <a href="/web/master-library" class="btn-primary">
          Explore the Library
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/web/maps" class="btn-ghost">View Map</a>
      </div>

      <div class="hero-roles" aria-label="Browse by role">
        <span class="roles-label">Browse as</span>
        <a href="/web/teacher" class="role-pill">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          Teacher
        </a>
        <a href="/web/student" class="role-pill">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          Student
        </a>
        <a href="/web/community-member" class="role-pill">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Community
        </a>
      </div>
    </div>

    <!-- Hero visual — abstract data grid -->
    <div class="hero-visual" aria-hidden="true">
      <div class="viz-card">
        <div class="viz-header">
          <span class="viz-dot r"></span>
          <span class="viz-dot y"></span>
          <span class="viz-dot g"></span>
          <span class="viz-label">census-acs-demographics.csv</span>
        </div>
        <div class="viz-table">
          <div class="vt-head">
            <span>county_fips</span><span>population</span><span>median_income</span><span>category</span>
          </div>
          {[
            ['17031', '5,275,541', '$62,088', 'Cook, IL'],
            ['06037', '9,829,544', '$71,358', 'LA, CA'],
            ['48201', '4,728,030', '$60,154', 'Harris, TX'],
            ['04013', '4,420,568', '$66,422', 'Maricopa, AZ'],
            ['06073', '3,338,330', '$79,506', 'San Diego, CA'],
            ['06059', '3,175,692', '$83,044', 'Orange, CA'],
          ].map(([fips, pop, income, name]) => (
            <div class="vt-row">
              <span class="mono">{fips}</span>
              <span class="mono">{pop}</span>
              <span class="mono">{income}</span>
              <span>{name}</span>
            </div>
          ))}
        </div>
        <div class="viz-footer">
          <span class="viz-tag">dataset</span>
          <span class="viz-tag">beginner</span>
          <span class="viz-tag">demographics</span>
          <span class="viz-more">+3,142 rows</span>
        </div>
      </div>

      <!-- Floating stat badges -->
      <div class="badge badge-1">
        <strong>500+</strong>
        <span>Curated resources</span>
      </div>
      <div class="badge badge-2">
        <strong>20</strong>
        <span>Global regions</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       STATS STRIP
  ═══════════════════════════════════════════ -->
  <div class="stats-strip" aria-label="Platform statistics">
    <div class="stat-item">
      <span class="stat-n">500+</span>
      <span class="stat-l">Curated Resources</span>
    </div>
    <div class="stat-sep" aria-hidden="true">·</div>
    <div class="stat-item">
      <span class="stat-n">1,000+</span>
      <span class="stat-l">Community Submissions</span>
    </div>
    <div class="stat-sep" aria-hidden="true">·</div>
    <div class="stat-item">
      <span class="stat-n">20</span>
      <span class="stat-l">Global Regions</span>
    </div>
    <div class="stat-sep" aria-hidden="true">·</div>
    <div class="stat-item">
      <span class="stat-n">100%</span>
      <span class="stat-l">Open Source</span>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       HOW IT WORKS  — editorial 3-column
  ═══════════════════════════════════════════ -->
  <section class="how-section" aria-label="How it works">
    <header class="section-header">
      <p class="section-eyebrow">How it works</p>
      <h2 class="section-title">Built for classrooms.<br/>Designed for communities.</h2>
    </header>

    <div class="how-grid">
      <div class="how-step">
        <div class="how-num">01</div>
        <h3>Curated catalog</h3>
        <p>Editors review and tag every resource — geographic coverage, audience level, statistical properties, and teaching notes included.</p>
      </div>
      <div class="how-step">
        <div class="how-num">02</div>
        <h3>Geography-first filtering</h3>
        <p>One dataset becomes thousands of access points. Search by county, ZIP, or school district and get pre-filled API URLs for your exact location.</p>
      </div>
      <div class="how-step">
        <div class="how-num">03</div>
        <h3>Community grows it</h3>
        <p>Teachers, students, and practitioners submit new resources. Everything is reviewed and version-controlled in Git.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FEATURE CARDS — 3-up
  ═══════════════════════════════════════════ -->
  <section class="features-section" aria-label="Key sections">
    <div class="feature-grid">

      <article class="feature-card fc-1">
        <div class="fc-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </div>
        <div class="fc-index">01</div>
        <h2 class="fc-title">Master Library</h2>
        <p class="fc-body">Expert-curated datasets, tools, guides, and research papers — organized by theme, difficulty, and audience role.</p>
        <a href="/web/master-library" class="fc-link">
          Explore resources
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </article>

      <article class="feature-card fc-2">
        <div class="fc-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="fc-index">02</div>
        <h2 class="fc-title">Community Library</h2>
        <p class="fc-body">Resources discovered and shared by practitioners, researchers, and teachers from around the world.</p>
        <a href="/web/community-library" class="fc-link">
          Browse community
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </article>

      <article class="feature-card fc-3">
        <div class="fc-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"/></svg>
        </div>
        <div class="fc-index">03</div>
        <h2 class="fc-title">Interactive Map</h2>
        <p class="fc-body">Explore open data portals, community organizations, and events on a global map with category filters.</p>
        <a href="/web/maps" class="fc-link">
          Open map
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </article>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CONTRIBUTE CTA BANNER
  ═══════════════════════════════════════════ -->
  <section class="cta-banner" aria-label="Contribute">
    <div class="cta-text">
      <p class="cta-eyebrow">Open to everyone</p>
      <h2 class="cta-title">Know a great resource?</h2>
      <p class="cta-body">Help the community by sharing datasets, tools, guides, or papers. All submissions are reviewed before publication.</p>
    </div>
    <div class="cta-actions">
      <a href="/web/submit" class="btn-primary btn-large">Submit a Resource →</a>
      <a href="https://github.com/community-data-libraries/web" target="_blank" rel="noopener noreferrer" class="cta-github">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
        View on GitHub
      </a>
    </div>
  </section>

</Layout>

<style>
  /* ══════════════════════════════════════════════
     HERO
  ══════════════════════════════════════════════ */
  .hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    padding: var(--space-12) 0 var(--space-16);
    align-items: center;
  }

  @media (min-width: 900px) {
    .hero {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
      min-height: 560px;
    }
  }

  /* Text side */
  .hero-text {
    display: grid;
    gap: var(--space-6);
    animation: fadeUp 0.7s ease both;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    font-weight: 500;
    color: var(--color-primary);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .kicker-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%  { opacity: 0.5; transform: scale(0.75); }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--color-text);
    margin: 0;
  }

  .hero-title em {
    font-style: italic;
    color: var(--color-primary);
  }

  .hero-body {
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    line-height: var(--line-height-relaxed);
    margin: 0;
    max-width: 44ch;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    align-items: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    background: var(--color-primary);
    color: #FFF8F4;
    border: 1.5px solid var(--color-primary);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: all 0.18s ease;
    cursor: pointer;
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
    box-shadow: var(--shadow-glow-primary);
    transform: translateY(-1px);
    text-decoration: none;
    color: #FFF8F4;
  }

  .btn-primary svg { transition: transform 0.18s ease; }
  .btn-primary:hover svg { transform: translateX(3px); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-5);
    background: transparent;
    color: var(--color-text-muted);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.18s ease;
    white-space: nowrap;
  }

  .btn-ghost:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-glow);
    text-decoration: none;
    transform: translateY(-1px);
  }

  /* Role pills */
  .hero-roles {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .roles-label {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-right: var(--space-1);
  }

  .role-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: 999px;
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .role-pill:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-glow);
    text-decoration: none;
  }

  /* ── Visual side ──────────────────────────── */
  .hero-visual {
    position: relative;
    animation: fadeUp 0.7s 0.15s ease both;
  }

  .viz-card {
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .viz-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface-raised);
    border-bottom: 1.5px solid var(--color-border);
  }

  .viz-dot {
    width: 9px; height: 9px;
    border-radius: 50%;
    display: block;
    flex-shrink: 0;
  }

  .viz-dot.r { background: #E57373; }
  .viz-dot.y { background: #FFB74D; }
  .viz-dot.g { background: #81C784; }

  .viz-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-text-dim);
    margin-left: var(--space-2);
  }

  .viz-table { padding: 0; }

  .vt-head {
    display: grid;
    grid-template-columns: 80px 100px 120px 1fr;
    gap: 0;
    padding: var(--space-2) var(--space-4);
    background: var(--color-surface-raised);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-primary);
    font-weight: 500;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .vt-row {
    display: grid;
    grid-template-columns: 80px 100px 120px 1fr;
    gap: 0;
    padding: var(--space-2) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.68rem;
    transition: background 0.12s ease;
  }

  .vt-row:last-child { border-bottom: none; }
  .vt-row:hover { background: var(--color-primary-glow); }

  .vt-row .mono { color: var(--color-text); }

  .viz-footer {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface-raised);
    border-top: 1.5px solid var(--color-border);
    flex-wrap: wrap;
  }

  .viz-tag {
    padding: 2px 8px;
    background: var(--color-primary-glow);
    border: 1px solid rgba(194, 65, 12, 0.2);
    border-radius: var(--radius-sm);
    font-size: 0.62rem;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .viz-more {
    margin-left: auto;
    font-size: 0.65rem;
    color: var(--color-text-dim);
  }

  /* Floating badges */
  .badge {
    position: absolute;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: column;
    gap: 2px;
    animation: float 4s ease-in-out infinite;
  }

  .badge strong {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .badge span {
    font-size: 0.65rem;
    color: var(--color-text-dim);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .badge-1 {
    bottom: -24px;
    left: -20px;
    animation-delay: 0s;
  }

  .badge-2 {
    top: -20px;
    right: -16px;
    animation-delay: 1.5s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @media (max-width: 899px) {
    .badge { display: none; }
  }

  /* ══════════════════════════════════════════════
     STATS STRIP
  ══════════════════════════════════════════════ */
  .stats-strip {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    flex-wrap: wrap;
    padding: var(--space-6) var(--space-8);
    background: var(--color-text);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-16);
    position: relative;
    overflow: hidden;
  }

  /* Decorative stripe */
  .stats-strip::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent-light), var(--color-secondary-light));
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .stat-n {
    font-family: var(--font-display);
    font-size: var(--font-size-3xl);
    font-weight: 900;
    color: var(--color-primary-light);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .stat-l {
    font-size: var(--font-size-xs);
    color: #8A7A6A;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .stat-sep {
    font-size: 1.5rem;
    color: #3A2A1A;
    user-select: none;
    display: none;
  }

  @media (min-width: 640px) {
    .stat-sep { display: block; }
  }

  /* ══════════════════════════════════════════════
     HOW IT WORKS
  ══════════════════════════════════════════════ */
  .how-section {
    margin-bottom: var(--space-16);
  }

  .section-header {
    margin-bottom: var(--space-12);
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-3);
  }

  .section-title {
    font-family: var(--font-display);

---
import CommunityLayout from '@layouts/CommunityLayout.astro';
import { withBasePath } from '@lib/paths';

const base = '/example-community-library';
const submitHref = withBasePath('/submit');
---

<CommunityLayout
  title="Data Resources"
  description="Submit datasets, explore lesson plans, and find community activity guides for Knox County."
  communityName="Knox County Data Library"
  communityLocation="Knox County, Tennessee"
  communityBase={base}
>
  <section class="data-resources-shell">
    <header class="page-header">
      <p class="eyebrow">Data Resources</p>
      <h1>Find the right path for data work.</h1>
      <p class="intro">
        Use this section to suggest a dataset, explore lesson plans, and follow upcoming community activities for Knox County.
      </p>
    </header>

    <div class="resource-grid">
      <article class="resource-card" id="submit">
        <div class="card-icon">01</div>
        <h2>Suggest a Dataset</h2>
        <p>Know an open dataset relevant to Knox County? Submit it for review and inclusion in this catalog.</p>
        <a href={submitHref} class="button">Go to submission form</a>
      </article>

      <article class="resource-card" id="lesson-plans">
        <div class="card-icon">02</div>
        <h2>Lesson Plans &amp; Resources</h2>
        <p>Classroom-ready materials built around Knox County datasets are planned for next summer.</p>
        <span class="status-pill">Coming next summer</span>
      </article>

      <article class="resource-card" id="community-activities">
        <div class="card-icon">03</div>
        <h2>Community Activities</h2>
        <p>Guides and workshop materials for community sessions in Knox County are planned for a later release.</p>
        <span class="status-pill">Coming in two summers</span>
      </article>
    </div>
  </section>

  <style>
    .data-resources-shell { display: grid; gap: var(--space-8); }
    .page-header { display: grid; gap: var(--space-3); max-width: 70ch; }
    .eyebrow { margin: 0; text-transform: uppercase; letter-spacing: 0.08em; font-size: var(--font-size-xs); font-weight: 700; color: var(--color-secondary); }
    .intro { margin: 0; color: var(--color-text-muted); font-size: var(--font-size-lg); line-height: var(--line-height-relaxed); }

    .resource-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
    @media (min-width: 640px)  { .resource-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1024px) { .resource-grid { grid-template-columns: repeat(3, 1fr); } }

    .resource-card {
      background: var(--color-surface); border: 1.5px solid var(--color-border);
      border-radius: var(--radius-xl); padding: var(--space-8) var(--space-6);
      display: grid; gap: var(--space-4); align-content: start;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .resource-card:hover { border-color: var(--color-secondary); box-shadow: var(--shadow-sm); }

    .card-icon {
      font-family: var(--font-display); font-size: 2.5rem; font-weight: 900;
      color: var(--color-secondary); line-height: 1; letter-spacing: -0.05em; opacity: 0.35;
    }

    .resource-card h2 { margin: 0; font-size: var(--font-size-2xl); letter-spacing: -0.02em; }
    .resource-card p  { margin: 0; color: var(--color-text-muted); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); }

    .button {
      background: var(--color-secondary); border-color: var(--color-secondary);
      align-self: start; justify-self: start;
    }
    .button:hover { background: var(--color-secondary-light); border-color: var(--color-secondary-light); box-shadow: var(--shadow-glow-secondary); }

    .status-pill {
      display: inline-flex; align-items: center; padding: var(--space-2) var(--space-3);
      background: var(--color-surface-raised); border: 1.5px solid var(--color-border);
      border-radius: 999px; font-size: var(--font-size-xs); font-weight: 600;
      color: var(--color-text-muted); letter-spacing: 0.02em; align-self: start; justify-self: start;
    }
  </style>
</CommunityLayout>

---
import CommunityLayout from '@layouts/CommunityLayout.astro';
import { getCollection } from 'astro:content';
import { canAudienceAccess } from '@lib/data/libraryAccess';
import { withBasePath } from '@lib/paths';

const allResources = await getCollection('master-library');
const knoxResources = allResources.filter(r => r.data.tags.includes('knox-county'));

const sorted = [...knoxResources].sort((a, b) => {
  const at = a.data.publishedDate ? new Date(a.data.publishedDate).getTime() : 0;
  const bt = b.data.publishedDate ? new Date(b.data.publishedDate).getTime() : 0;
  return bt - at;
});

function getAudiences(resource: (typeof allResources)[number]): string {
  const audiences: string[] = [];
  if (canAudienceAccess(resource, 'teacher'))   audiences.push('teacher');
  if (canAudienceAccess(resource, 'student'))   audiences.push('student');
  if (canAudienceAccess(resource, 'community')) audiences.push('community');
  return audiences.join(' ');
}

function formatDate(date: Date | undefined): string {
  if (!date) return '';
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const base = '/example-community-library';
---

<CommunityLayout
  title="Catalog"
  description="Knox County dataset catalog — browse by role: Teacher, Student, or Community Member."
  communityName="Knox County Data Library"
  communityLocation="Knox County, Tennessee"
  communityBase={base}
>
  <div class="catalog-shell">

    <!-- ── Page header ────────────────────────── -->
    <header class="page-header">
      <p class="eyebrow">Dataset Catalog</p>
      <h1>Knox County Datasets</h1>
      <p class="intro">
        Choose your role below to see a tailored view of the catalog.
        Teachers see pedagogical tags; students see a filtered, age-appropriate set.
      </p>
    </header>

    <!-- ── Role picker ────────────────────────── -->
    <section class="role-picker" aria-label="Choose your role">
      <div class="role-grid">
        <button class="role-card role-card-teacher active" data-audience="teacher" id="btn-teacher">
          <div class="role-card-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
          </div>
          <h3>Teacher</h3>
          <p>Full catalog with pedagogical tags and classroom planning support.</p>
        </button>
        <button class="role-card role-card-student" data-audience="student" id="btn-student">
          <div class="role-card-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          </div>
          <h3>Student</h3>
          <p>Student-safe view with sensitive datasets removed.</p>
        </button>
        <button class="role-card role-card-community" data-audience="community" id="btn-community">
          <div class="role-card-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Community Member</h3>
          <p>Complete unfiltered catalog for local exploration.</p>
        </button>
      </div>
    </section>

    <!-- ── Catalog ────────────────────────────── -->
    <section class="catalog" id="knox-catalog" data-audience="teacher" aria-label="Knox County datasets">
      <div class="catalog-header">
        <h2 id="catalog-heading">Knox County Datasets — Teacher View</h2>
        <p id="catalog-count"><strong>{sorted.length}</strong> datasets</p>
      </div>

      {sorted.length === 0 ? (
        <p class="empty">No datasets found for Knox County yet.</p>
      ) : (
        <div class="cards">
          {sorted.map(resource => {
            const themes = resource.data.dataThemes.length > 0
              ? resource.data.dataThemes
              : resource.data.tags.filter(t => t !== 'knox-county' && t !== 'local' && t !== 'tennessee');
            const previewHref = withBasePath(`/data-preview?entry=${encodeURIComponent(resource.id)}&audience=AUDIENCE_PLACEHOLDER`);
            const resourceAudiences = getAudiences(resource);
            return (
              <article class="dataset-card" data-audiences={resourceAudiences}>
                <div class="card-body">
                  <h3><a href={previewHref} class="preview-link">{resource.data.title}</a></h3>
                  <p>{resource.data.description}</p>
                  <div class="chips">
                    {themes.slice(0, 3).map(t => <span class="chip chip-theme">{t}</span>)}
                    {resource.data.pedagogicalTags.slice(0, 2).map(t => (
                      <span class="chip chip-pedagogical">{t}</span>
                    ))}
                  </div>
                  {resource.data.publishedDate && (
                    <p class="meta">Updated {formatDate(resource.data.publishedDate)}</p>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      )}
    </section>

  </div>

  <script>
    const catalog  = document.getElementById('knox-catalog');
    const heading  = document.getElementById('catalog-heading');
    const countEl  = document.getElementById('catalog-count');
    const roleBtns = document.querySelectorAll<HTMLElement>('.role-card[data-audience]');

    const headingLabels: Record<string, string> = {
      teacher:   'Knox County Datasets — Teacher View',
      student:   'Knox County Datasets — Student View',
      community: 'Knox County Datasets — Community View',
    };

    function applyAudience(audience: string) {
      if (!catalog) return;
      catalog.dataset.audience = audience;
      roleBtns.forEach(btn => btn.classList.toggle('active', btn.dataset.audience === audience));
      if (heading) heading.textContent = headingLabels[audience] ?? headingLabels.community;
      document.querySelectorAll<HTMLAnchorElement>('.preview-link').forEach(link => {
        link.href = link.href.replace(/audience=[^&]+/, `audience=${audience}`);
      });
      if (countEl) {
        let count = 0;
        catalog.querySelectorAll<HTMLElement>('.dataset-card').forEach(card => {
          if ((card.dataset.audiences ?? '').split(' ').includes(audience)) count++;
        });
        countEl.innerHTML = `<strong>${count}</strong> datasets`;
      }
    }

    roleBtns.forEach(btn => {
      btn.addEventListener('click', () => applyAudience(btn.dataset.audience ?? 'community'));
    });

    // Support hash-based pre-selection from the home page role cards
    const hash = location.hash.replace('#', '');
    applyAudience(['teacher','student','community'].includes(hash) ? hash : 'teacher');
  </script>

  <style>
    .catalog-shell { display: grid; gap: var(--space-10); }

    .page-header { display: grid; gap: var(--space-3); max-width: 72ch; }
    .eyebrow { margin: 0; text-transform: uppercase; letter-spacing: 0.08em; font-size: var(--font-size-xs); font-weight: 700; color: var(--color-secondary); }
    .intro { margin: 0; color: var(--color-text-muted); font-size: var(--font-size-lg); line-height: var(--line-height-relaxed); }

    /* Role picker */
    .role-picker { display: grid; gap: var(--space-4); }
    .role-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
    @media (min-width: 900px) { .role-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }

    .role-card {
      appearance: none; -webkit-appearance: none; font-family: var(--font-sans);
      font-size: inherit; white-space: normal; width: 100%;
      border: 2px solid var(--color-border); background: var(--color-surface);
      border-radius: var(--radius-xl); padding: var(--space-5); display: grid;
      gap: var(--space-2); text-align: left; cursor: pointer;
      transition: border-color 0.15s ease, background 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
    }
    .role-card:hover { transform: translateY(-1px); box-shadow: var(--shadow-sm); }
    .role-card-teacher.active  { border-color: var(--color-primary);    background: var(--color-primary-glow); }
    .role-card-student.active  { border-color: var(--color-secondary);  background: var(--color-secondary-glow); }
    .role-card-community.active { border-color: var(--color-accent);    background: var(--color-accent-glow); }
    .role-card-icon { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: var(--radius-md); margin-bottom: var(--space-1); }
    .role-card-teacher   .role-card-icon { background: var(--color-primary-glow);   color: var(--color-primary); }
    .role-card-student   .role-card-icon { background: var(--color-secondary-glow); color: var(--color-secondary); }
    .role-card-community .role-card-icon { background: var(--color-accent-glow);    color: var(--color-accent); }
    .role-card h3 { margin: 0; font-size: var(--font-size-xl); color: var(--color-text); }
    .role-card p  { margin: 0; color: var(--color-text-muted); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); }

    /* Catalog */
    .catalog { display: grid; gap: var(--space-4); }
    .catalog-header {
      display: flex; align-items: center; justify-content: space-between; gap: var(--space-3);
      flex-wrap: wrap; border-bottom: 1px solid var(--color-border); padding-bottom: var(--space-3);
    }
    .catalog-header h2 { margin: 0; font-size: var(--font-size-xl); }
    .catalog-header p  { margin: 0; color: var(--color-text-muted); font-size: var(--font-size-sm); }
    .catalog-header strong { color: var(--color-text); }
    .cards { display: grid; gap: var(--space-3); }

    /* Audience visibility */
    #knox-catalog[data-audience="teacher"]   .dataset-card:not([data-audiences~="teacher"])   { display: none; }
    #knox-catalog[data-audience="student"]   .dataset-card:not([data-audiences~="student"])   { display: none; }
    #knox-catalog[data-audience="community"] .dataset-card:not([data-audiences~="community"]) { display: none; }
    #knox-catalog:not([data-audience="teacher"]) .chip-pedagogical { display: none; }

    .dataset-card { border: 1px solid var(--color-border); border-radius: var(--radius-lg); background: var(--color-surface); transition: border-color 0.15s ease; }
    .dataset-card:hover { border-color: var(--color-border-highlight); }
    .card-body { padding: var(--space-5); display: grid; gap: var(--space-3); }
    .card-body h3 { margin: 0; font-size: var(--font-size-lg); letter-spacing: -0.02em; }
    .card-body h3 a { color: var(--color-text); text-decoration: none; transition: color 0.15s ease; }
    .card-body h3 a:hover { color: var(--color-secondary); }
    .card-body > p { margin: 0; color: var(--color-text-muted); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); }
    .meta { color: var(--color-text-dim); font-family: var(--font-mono); font-size: var(--font-size-xs); }
    .empty { color: var(--color-text-dim); font-style: italic; }

    .chips { display: flex; flex-wrap: wrap; gap: var(--space-2); }
    .chip {
      display: inline-flex; align-items: center; padding: 2px var(--space-2);
      border-radius: var(--radius-sm); border: 1px solid var(--color-border);
      font-size: var(--font-size-xs); font-weight: 500; color: var(--color-text-muted); background: var(--color-surface-raised);
    }
    .chip-theme     { border-color: rgba(21,94,117,0.25);  color: var(--color-secondary); background: rgba(21,94,117,0.08); }
    .chip-pedagogical { border-color: rgba(14,114,101,0.25); color: var(--color-primary);   background: var(--color-primary-glow); }
  </style>
</CommunityLayout>

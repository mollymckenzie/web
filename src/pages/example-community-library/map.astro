---
import CommunityLayout from '@layouts/CommunityLayout.astro';
import { loadGeoMarkers } from '@lib/data/geo';
import type { GeoMarkerFeature } from '@lib/types/geo';

const collection = loadGeoMarkers();
const features = collection.features as GeoMarkerFeature[];

const base = '/example-community-library';
---

<CommunityLayout
  title="Map"
  description="Geographic map of community data resources in Knox County, Tennessee."
  communityName="Knox County Data Library"
  communityLocation="Knox County, Tennessee"
  communityBase={base}
>
  <section>
    <header class="page-header">
      <p class="eyebrow">Community Map</p>
      <h1>Knox County Map</h1>
      <p class="intro">
        Click anywhere on the map to drop a pin and see the nearest datasets for that location.
        The map starts centered on Knox County, Tennessee.
      </p>
    </header>

    <div class="map-shell">
      <div class="map-panel" id="map-panel" aria-live="polite">
        <p class="panel-eyebrow">Local preview</p>
        <h2 id="panel-title">Drop a pin on the map</h2>
        <p id="panel-copy">We'll surface the closest datasets in the Knox County catalog for that location.</p>
        <div id="nearby-list" class="nearby-list">
          <p class="empty-copy">No pin selected yet.</p>
        </div>
      </div>
      <div id="map" role="region" aria-label="Knox County community map"></div>
    </div>

    <script type="application/json" id="geojson-data" set:html={JSON.stringify(collection)}></script>

    <script is:inline>
      (function loadLeaflet() {
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
        document.head.appendChild(link);
        var s = document.createElement('script');
        s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
        s.onload = initMap;
        document.head.appendChild(s);
      })();

      function initMap() {
        // Center on Knox County, TN
        var map = L.map('map', { scrollWheelZoom: false }).setView([35.9606, -83.9207], 10);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(map);

        var el = document.getElementById('geojson-data');
        if (!el || !el.textContent) return;
        var data = JSON.parse(el.textContent);

        var colors = { dataset: '#155E75', site: '#166534', organization: '#B45309', event: '#9A3412', other: '#A8927A' };
        var registry = [];

        for (var i = 0; i < (data.features || []).length; i++) {
          var feature = data.features[i];
          if (!feature || feature.type !== 'Feature') continue;
          var coords = feature.geometry && feature.geometry.coordinates;
          if (!Array.isArray(coords) || coords.length < 2) continue;
          var lon = coords[0], lat = coords[1];
          var cat = (feature.properties && feature.properties.category) || 'other';
          var marker = L.circleMarker([lat, lon], {
            radius: 6, color: colors[cat] || colors.other, weight: 2,
            fillColor: colors[cat] || colors.other, fillOpacity: 0.8
          }).addTo(map);
          var name = (feature.properties && feature.properties.name) || 'Unknown';
          var url = feature.properties && feature.properties.sourceUrl;
          marker.bindPopup('<strong>' + name + '</strong><br/>Category: ' + cat + (url ? '<br/><a href="' + url + '" target="_blank" rel="noopener">Source</a>' : ''));
          registry.push({ lat: lat, lon: lon, title: name, url: url, tags: Array.isArray(feature.properties && feature.properties.tags) ? feature.properties.tags : [] });
        }

        setTimeout(function() { map.invalidateSize({ animate: false }); }, 50);

        function haversine(lat1, lon1, lat2, lon2) {
          var R = 6371, toRad = function(v) { return v * Math.PI / 180; };
          var dLat = toRad(lat2 - lat1), dLon = toRad(lon2 - lon1);
          var a = Math.sin(dLat/2)*Math.sin(dLat/2) + Math.cos(toRad(lat1))*Math.cos(toRad(lat2))*Math.sin(dLon/2)*Math.sin(dLon/2);
          return 2 * R * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        }

        map.on('click', function(e) {
          var lat = e.latlng.lat, lon = e.latlng.lng;
          var nearby = registry.map(function(item) {
            return Object.assign({}, item, { distance: haversine(lat, lon, item.lat, item.lon) });
          }).sort(function(a, b) { return a.distance - b.distance; }).slice(0, 8);

          var panelTitle = document.getElementById('panel-title');
          var panelCopy = document.getElementById('panel-copy');
          var nearbyList = document.getElementById('nearby-list');
          if (panelTitle) panelTitle.textContent = 'Nearby datasets';
          if (panelCopy) panelCopy.textContent = 'Closest Knox County catalog resources to your pin.';
          if (!nearbyList) return;
          nearbyList.innerHTML = nearby.length > 0 ? nearby.map(function(item) {
            var tagText = item.tags.slice(0, 3).join(', ');
            return '<div class="nearby-item">' +
              (item.url ? '<a href="' + item.url + '" target="_blank" rel="noopener" class="nearby-title">' + item.title + '</a>' : '<span class="nearby-title">' + item.title + '</span>') +
              '<span class="nearby-dist">' + item.distance.toFixed(1) + ' km away</span>' +
              (tagText ? '<span class="nearby-tags">' + tagText + '</span>' : '') +
              '</div>';
          }).join('') : '<p class="empty-copy">No resources found near this location.</p>';
        });
      }
    </script>
  </section>
</CommunityLayout>

<style>
  .page-header { display: grid; gap: var(--space-3); max-width: 72ch; margin-bottom: var(--space-8); }
  .eyebrow { margin: 0; text-transform: uppercase; letter-spacing: 0.08em; font-size: var(--font-size-xs); font-weight: 700; color: var(--color-secondary); }
  .intro { margin: 0; color: var(--color-text-muted); font-size: var(--font-size-lg); line-height: var(--line-height-relaxed); }

  .map-shell {
    display: grid; grid-template-columns: 1fr; gap: 0;
    border: 1.5px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden;
    box-shadow: var(--shadow-md); height: 540px;
  }
  @media (min-width: 768px) { .map-shell { grid-template-columns: 300px 1fr; } }

  .map-panel {
    background: var(--color-surface); padding: var(--space-5); display: grid; gap: var(--space-3);
    align-content: start; border-right: 1px solid var(--color-border); overflow-y: auto;
  }
  .panel-eyebrow { font-family: var(--font-mono); font-size: var(--font-size-xs); font-weight: 600; color: var(--color-secondary); text-transform: uppercase; letter-spacing: 0.08em; margin: 0; }
  .map-panel h2 { margin: 0; font-size: var(--font-size-xl); }
  .map-panel p  { margin: 0; color: var(--color-text-muted); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); }

  #map { flex: 1; min-height: 300px; }

  .nearby-list { display: grid; gap: var(--space-3); }
  .nearby-item { display: grid; gap: var(--space-1); padding: var(--space-3); background: var(--color-surface-raised); border-radius: var(--radius-md); border: 1px solid var(--color-border); }
  .nearby-title { font-weight: 600; font-size: var(--font-size-sm); color: var(--color-text); text-decoration: none; }
  a.nearby-title:hover { color: var(--color-secondary); text-decoration: underline; }
  .nearby-dist  { font-family: var(--font-mono); font-size: var(--font-size-xs); color: var(--color-text-dim); }
  .nearby-tags  { font-size: var(--font-size-xs); color: var(--color-text-muted); }
  .empty-copy   { color: var(--color-text-dim); font-style: italic; font-size: var(--font-size-sm); margin: 0; }
</style>

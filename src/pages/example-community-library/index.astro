---
import CommunityLayout from '@layouts/CommunityLayout.astro';
import { getCollection } from 'astro:content';
import { withBasePath } from '@lib/paths';

const allResources = await getCollection('master-library');
const knoxResources = allResources.filter(r => r.data.tags.includes('knox-county'));
const datasetCount = knoxResources.filter(r => r.data.category === 'dataset').length;
const themeCount = new Set(knoxResources.flatMap(r => r.data.dataThemes)).size;

const base = '/example-community-library';
const catalogHref = withBasePath(`${base}/catalog`);
const mapHref     = withBasePath(`${base}/map`);
const submitHref  = withBasePath('/submit');
---

<CommunityLayout
  title="Home"
  description="Knox County Community Data Library — curated local datasets for teachers, students, and community members in Knox County, Tennessee."
  communityName="Knox County Data Library"
  communityLocation="Knox County, Tennessee"
  communityBase={base}
>

  <!-- ── Hero ──────────────────────────────────── -->
  <section class="hero" aria-label="Introduction">
    <div class="hero-text">
      <div class="hero-kicker">Knox County · Tennessee · Open Data</div>
      <h1 class="hero-title">
        Local data, <em class="word-for">for</em><br/>
        every learner.
      </h1>
      <p class="hero-body">
        A curated catalog of open datasets about Knox County — filtered and organized for
        teachers, students, and community members.
      </p>
      <div class="hero-actions">
        <a href={catalogHref} class="btn-primary">
          Explore the Catalog
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href={mapHref} class="btn-ghost">View Map</a>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="viz-card">
        <div class="viz-header">
          <span class="viz-dot r"></span>
          <span class="viz-dot y"></span>
          <span class="viz-dot g"></span>
          <span class="viz-label">knox-county-demographics.csv</span>
        </div>
        <div class="viz-table">
          <div class="vt-head">
            <span>tract_id</span><span>population</span><span>median_income</span><span>area</span>
          </div>
          {[
            ['47093001', '4,213', '$54,200', 'Knoxville North'],
            ['47093002', '3,891', '$61,500', 'Knoxville South'],
            ['47093003', '5,044', '$47,800', 'Powell'],
            ['47093004', '4,612', '$58,900', 'Farragut'],
            ['47093005', '3,278', '$72,100', 'West Hills'],
          ].map(([id, pop, income, area]) => (
            <div class="vt-row">
              <span class="mono">{id}</span>
              <span class="mono">{pop}</span>
              <span class="mono">{income}</span>
              <span>{area}</span>
            </div>
          ))}
        </div>
        <div class="viz-footer">
          <span class="viz-tag">dataset</span>
          <span class="viz-tag">demographics</span>
          <span class="viz-tag">knox-county</span>
        </div>
      </div>
      <div class="badge badge-1">
        <strong>{knoxResources.length}</strong>
        <span>Local datasets</span>
      </div>
      <div class="badge badge-2">
        <strong>{themeCount}</strong>
        <span>Data themes</span>
      </div>
    </div>
  </section>

  <!-- ── Stats ─────────────────────────────────── -->
  <div class="stats-strip" aria-label="Library statistics">
    <div class="stat-item">
      <span class="stat-n">{knoxResources.length}</span>
      <span class="stat-l">Datasets</span>
    </div>
    <div class="stat-sep" aria-hidden="true">·</div>
    <div class="stat-item">
      <span class="stat-n">{datasetCount}</span>
      <span class="stat-l">Raw Datasets</span>
    </div>
    <div class="stat-sep" aria-hidden="true">·</div>
    <div class="stat-item">
      <span class="stat-n">{themeCount}</span>
      <span class="stat-l">Themes</span>
    </div>
    <div class="stat-sep" aria-hidden="true">·</div>
    <div class="stat-item">
      <span class="stat-n">3</span>
      <span class="stat-l">Audience Roles</span>
    </div>
    <div class="stat-sep" aria-hidden="true">·</div>
    <div class="stat-item">
      <span class="stat-n">100%</span>
      <span class="stat-l">Open Source</span>
    </div>
  </div>

  <!-- ── Browse by role ────────────────────────── -->
  <section class="roles-section" aria-label="Browse by role">
    <header class="section-header">
      <p class="section-eyebrow">Catalog views</p>
      <h2 class="section-title">Pick your role.<br/><span class="section-accent">See what's right for you.</span></h2>
    </header>
    <div class="roles-grid">
      <a href={`${catalogHref}#teacher`} class="role-card role-teacher">
        <div class="role-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
        </div>
        <h3>Teacher</h3>
        <p>Full catalog with pedagogical tags and classroom planning support.</p>
        <span class="role-cta">Explore →</span>
      </a>
      <a href={`${catalogHref}#student`} class="role-card role-student">
        <div class="role-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        </div>
        <h3>Student</h3>
        <p>Student-safe view with sensitive datasets removed.</p>
        <span class="role-cta">Explore →</span>
      </a>
      <a href={`${catalogHref}#community`} class="role-card role-community">
        <div class="role-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3>Community Member</h3>
        <p>Complete unfiltered catalog for local exploration.</p>
        <span class="role-cta">Explore →</span>
      </a>
    </div>
  </section>

  <!-- ── How it works ──────────────────────────── -->
  <section class="how-section" aria-label="How it works">
    <header class="section-header">
      <p class="section-eyebrow">How it works</p>
      <h2 class="section-title">Built for Knox County.<br/><span class="section-accent">Designed for every learner.</span></h2>
    </header>
    <div class="how-grid">
      <div class="how-step">
        <h3>Locally curated</h3>
        <p>Every dataset is reviewed and tagged for geographic coverage relevant to Knox County, Tennessee.</p>
      </div>
      <div class="how-step">
        <h3>Role-based views</h3>
        <p>Teachers see pedagogical metadata. Students see age-appropriate data. Community members see the full picture.</p>
      </div>
      <div class="how-step">
        <h3>Community-driven</h3>
        <p>Know a dataset that belongs here? Submit it and it will be reviewed for inclusion in the next catalog update.</p>
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────── -->
  <section class="cta-banner" aria-label="Contribute">
    <div class="cta-text">
      <p class="cta-eyebrow">Community-Driven</p>
      <h2 class="cta-title">Know an open dataset about Knox County?</h2>
      <p class="cta-body">Help expand the catalog by sharing openly available datasets. All submissions are reviewed before publication.</p>
    </div>
    <div class="cta-actions">
      <a href={submitHref} class="btn-primary btn-large">Submit a Dataset →</a>
    </div>
  </section>

</CommunityLayout>

<style>
  /* ── Hero ──────────────────────────────────── */
  .hero {
    display: grid; grid-template-columns: 1fr; gap: var(--space-12);
    padding: var(--space-12) 0 var(--space-16); align-items: center;
  }
  @media (min-width: 900px) { .hero { grid-template-columns: 1fr 1fr; gap: var(--space-16); min-height: 520px; } }

  .hero-text { display: grid; gap: var(--space-6); animation: fadeUp 0.7s ease both; }

  .hero-kicker {
    font-family: var(--font-mono); font-size: var(--font-size-xs); font-weight: 500;
    color: var(--color-secondary); letter-spacing: 0.06em; text-transform: uppercase;
  }

  .hero-title {
    font-family: var(--font-display); font-size: clamp(2.8rem, 6vw, 4.5rem); font-weight: 900;
    line-height: 1.0; letter-spacing: -0.04em; color: var(--color-text); margin: 0;
  }
  .hero-title em { font-style: italic; }
  .word-for { color: var(--color-secondary); }

  .hero-body { font-size: var(--font-size-lg); color: var(--color-text-muted); line-height: var(--line-height-relaxed); margin: 0; max-width: 44ch; }

  .hero-actions { display: flex; gap: var(--space-3); flex-wrap: wrap; align-items: center; }

  .btn-primary {
    display: inline-flex; align-items: center; gap: var(--space-2);
    padding: var(--space-3) var(--space-6); background: var(--color-secondary); color: #F8FAFC;
    border: 1.5px solid var(--color-secondary); border-radius: var(--radius-md);
    font-size: var(--font-size-sm); font-weight: 600; letter-spacing: 0.02em;
    text-decoration: none; transition: all 0.18s ease; white-space: nowrap;
  }
  .btn-primary:hover {
    background: var(--color-secondary-light); border-color: var(--color-secondary-light);
    box-shadow: var(--shadow-glow-secondary); transform: translateY(-1px); text-decoration: none; color: #F8FAFC;
  }
  .btn-primary svg { transition: transform 0.18s ease; }
  .btn-primary:hover svg { transform: translateX(3px); }

  .btn-ghost {
    display: inline-flex; align-items: center; padding: var(--space-3) var(--space-5);
    background: transparent; color: var(--color-text-muted); border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md); font-size: var(--font-size-sm); font-weight: 600;
    text-decoration: none; transition: all 0.18s ease; white-space: nowrap;
  }
  .btn-ghost:hover { border-color: var(--color-secondary); color: var(--color-secondary); background: var(--color-secondary-glow); text-decoration: none; transform: translateY(-1px); }

  /* Hero visual */
  .hero-visual { position: relative; animation: fadeUp 0.7s 0.15s ease both; }
  .viz-card {
    background: var(--color-surface); border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-lg);
    font-family: var(--font-mono); font-size: 0.72rem;
  }
  .viz-header {
    display: flex; align-items: center; gap: var(--space-2); padding: var(--space-3) var(--space-4);
    background: var(--color-surface-raised); border-bottom: 1.5px solid var(--color-border);
  }
  .viz-dot { width: 9px; height: 9px; border-radius: 50%; display: block; flex-shrink: 0; }
  .viz-dot.r { background: #E57373; }
  .viz-dot.y { background: #FFB74D; }
  .viz-dot.g { background: #81C784; }
  .viz-label { font-family: var(--font-mono); font-size: 0.68rem; color: var(--color-text-dim); margin-left: var(--space-2); }
  .vt-head {
    display: grid; grid-template-columns: 90px 90px 110px 1fr;
    padding: var(--space-2) var(--space-4); background: var(--color-surface-raised);
    border-bottom: 1px solid var(--color-border); color: var(--color-secondary);
    font-weight: 500; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.04em;
  }
  .vt-row {
    display: grid; grid-template-columns: 90px 90px 110px 1fr;
    padding: var(--space-2) var(--space-4); border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted); font-size: 0.68rem; transition: background 0.12s ease;
  }
  .vt-row:last-child { border-bottom: none; }
  .vt-row:hover { background: var(--color-secondary-glow); }
  .vt-row .mono { color: var(--color-text); }
  .viz-footer {
    display: flex; align-items: center; gap: var(--space-2); padding: var(--space-3) var(--space-4);
    background: var(--color-surface-raised); border-top: 1.5px solid var(--color-border); flex-wrap: wrap;
  }
  .viz-tag {
    padding: 2px 8px; background: var(--color-secondary-glow); border: 1px solid rgba(21,94,117,0.2);
    border-radius: var(--radius-sm); font-size: 0.62rem; font-weight: 600; color: var(--color-secondary);
    text-transform: uppercase; letter-spacing: 0.04em;
  }
  .badge {
    position: absolute; background: var(--color-surface); border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg); padding: var(--space-3) var(--space-4); box-shadow: var(--shadow-md);
    display: flex; flex-direction: column; gap: 2px; animation: float 4s ease-in-out infinite;
  }
  .badge strong { font-family: var(--font-display); font-size: 1.4rem; font-weight: 900; color: var(--color-secondary); line-height: 1; letter-spacing: -0.04em; }
  .badge span { font-size: 0.65rem; color: var(--color-text-dim); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }
  .badge-1 { bottom: -24px; left: -20px; animation-delay: 0s; }
  .badge-2 { top: -20px; right: -16px; animation-delay: 1.5s; }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
  @media (max-width: 899px) { .badge { display: none; } }

  /* ── Stats strip ───────────────────────────── */
  .stats-strip {
    display: flex; align-items: center; justify-content: center; gap: var(--space-6); flex-wrap: wrap;
    padding: var(--space-6) var(--space-8); background: var(--color-text); border-radius: var(--radius-lg);
    margin-bottom: var(--space-16); position: relative; overflow: hidden;
  }
  .stats-strip::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--color-secondary), var(--color-primary), var(--color-accent-light));
  }
  .stat-item { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .stat-n { font-family: var(--font-display); font-size: var(--font-size-3xl); font-weight: 900; color: var(--color-secondary-light); line-height: 1; letter-spacing: -0.04em; }
  .stat-l { font-size: var(--font-size-xs); color: #8A7A6A; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; }
  .stat-sep { font-size: 1.5rem; color: #3A2A1A; user-select: none; display: none; }
  @media (min-width: 640px) { .stat-sep { display: block; } }

  /* ── Roles section ─────────────────────────── */
  .roles-section { margin-bottom: var(--space-16); }
  .section-header { margin-bottom: var(--space-10); }
  .section-eyebrow {
    font-family: var(--font-mono); font-size: var(--font-size-xs); font-weight: 600;
    color: var(--color-secondary); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-3);
  }
  .section-title {
    font-family: var(--font-display); font-size: clamp(var(--font-size-3xl), 4vw, 3rem);
    font-weight: 900; line-height: 1.1; letter-spacing: -0.03em; color: var(--color-text); margin: 0;
  }
  .section-accent { color: var(--color-secondary); }

  .roles-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-4); }
  @media (min-width: 900px) { .roles-grid { grid-template-columns: repeat(3, 1fr); } }

  .role-card {
    background: var(--color-surface); border: 1.5px solid var(--color-border);
    border-radius: var(--radius-xl); padding: var(--space-6); display: grid;
    gap: var(--space-3); align-content: start; text-decoration: none; color: inherit;
    transition: all 0.18s ease; position: relative; overflow: hidden;
  }
  .role-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); text-decoration: none; }
  .role-teacher:hover { border-color: var(--color-primary); background: var(--color-primary-glow); }
  .role-student:hover { border-color: var(--color-secondary); background: var(--color-secondary-glow); }
  .role-community:hover { border-color: var(--color-accent); background: var(--color-accent-glow); }
  .role-icon { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; border-radius: var(--radius-md); background: var(--color-surface-raised); margin-bottom: var(--space-2); }
  .role-teacher .role-icon { background: var(--color-primary-glow); color: var(--color-primary); }
  .role-student .role-icon { background: var(--color-secondary-glow); color: var(--color-secondary); }
  .role-community .role-icon { background: var(--color-accent-glow); color: var(--color-accent); }
  .role-card h3 { font-family: var(--font-display); font-size: var(--font-size-xl); font-weight: 700; color: var(--color-text); margin: 0; }
  .role-card p { margin: 0; color: var(--color-text-muted); font-size: var(--font-size-sm); line-height: var(--line-height-relaxed); }
  .role-cta { font-size: var(--font-size-sm); font-weight: 700; color: var(--color-text-muted); margin-top: var(--space-2); }
  .role-teacher:hover .role-cta { color: var(--color-primary); }
  .role-student:hover .role-cta { color: var(--color-secondary); }
  .role-community:hover .role-cta { color: var(--color-accent); }

  /* ── How it works ──────────────────────────── */
  .how-section { margin-bottom: var(--space-16); }
  .how-grid {
    display: grid; grid-template-columns: 1fr; border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg); overflow: hidden; background: var(--color-border);
  }
  @media (min-width: 768px) { .how-grid { grid-template-columns: repeat(3, 1fr); } }
  .how-step { background: var(--color-surface); padding: var(--space-8) var(--space-6); display: grid; gap: var(--space-3); align-content: start; transition: background 0.15s ease; }
  .how-step:hover { background: var(--color-surface-raised); }
  .how-step h3 { font-family: var(--font-display); font-size: var(--font-size-xl); font-weight: 700; color: var(--color-text); margin: 0; }
  .how-step p { margin: 0; font-size: var(--font-size-sm); color: var(--color-text-muted); line-height: var(--line-height-relaxed); }

  /* ── CTA banner ────────────────────────────── */
  .cta-banner {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-8);
    padding: var(--space-12) var(--space-16); background: var(--color-surface-raised);
    border: 1.5px solid var(--color-border); border-radius: var(--radius-xl);
    position: relative; overflow: hidden; flex-wrap: wrap; margin-bottom: var(--space-8);
  }
  .cta-banner::before {
    content: ''; position: absolute; top: 0; bottom: 0; left: 40%; width: 1.5px;
    background: var(--color-border); transform: rotate(8deg) scaleY(1.5); opacity: 0.4;
  }
  .cta-text { flex: 1; min-width: 260px; position: relative; z-index: 1; }
  .cta-eyebrow {
    font-family: var(--font-mono); font-size: var(--font-size-xs); font-weight: 600;
    color: var(--color-secondary); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: var(--space-2);
  }
  .cta-title { font-family: var(--font-display); font-size: var(--font-size-3xl); font-weight: 900; color: var(--color-text); margin: 0 0 var(--space-3); letter-spacing: -0.03em; }
  .cta-body { margin: 0; font-size: var(--font-size-base); color: var(--color-text-muted); line-height: var(--line-height-relaxed); max-width: 44ch; }
  .cta-actions { flex-shrink: 0; position: relative; z-index: 1; }
  .btn-large { padding: var(--space-4) var(--space-8); font-size: var(--font-size-base); }
</style>

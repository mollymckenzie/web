---
import Layout from '@layouts/Layout.astro';
import { loadGeoMarkers } from '@lib/data/geo';
import type { GeoMarkerFeature } from '@lib/types/geo';

const collection = loadGeoMarkers();
const features = collection.features as GeoMarkerFeature[];
---

<Layout title="Community Map" description="Geographic markers for community data libraries">
  <!-- Leaflet CSS/JS via CDN -->
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4Qj7v+ZtPjRrQqkKeNU5B0sB8rQkD+WfYV5b7rR/nM="
    crossorigin=""
  />
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-VzL9bF7gCwEoEkQ3JwXj7c9bGmF+WjUZbQhVfReN+pA="
    crossorigin=""
  ></script>
  <section>
    <h1>Community Map</h1>
    <p>Interactive map of community data library locations, datasets, organizations, and events.</p>

    <div id="map" role="region" aria-label="Community map"></div>

    <form id="map-filters" class="filters" aria-label="Filter markers">
      <fieldset>
        <legend>Filter by category</legend>
        <label><input type="checkbox" name="category" value="dataset" checked /> Dataset</label>
        <label><input type="checkbox" name="category" value="site" checked /> Site</label>
        <label><input type="checkbox" name="category" value="organization" checked /> Organization</label>
        <label><input type="checkbox" name="category" value="event" checked /> Event</label>
        <label><input type="checkbox" name="category" value="other" checked /> Other</label>
      </fieldset>
      <label class="tag-filter">
        <span>Tags contains</span>
        <input type="text" id="tag-query" placeholder="e.g., transport" />
      </label>
    </form>

    <!-- Embed GeoJSON data for client-side usage -->
    <script type="application/json" id="geojson-data">
      {JSON.stringify(collection)}
    </script>

    <script>
      // Initialize Leaflet map after DOM is ready
      document.addEventListener('DOMContentLoaded', () => {
        if (!window.L) return;
        const map = L.map('map');
        // Base layer
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution:
            '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(map);

        // Parse embedded geojson
        const el = document.getElementById('geojson-data');
        if (!el || !el.textContent) return;
        const data = JSON.parse(el.textContent);

        // Prepare data structures
        const bounds = L.latLngBounds([]);
        const registry = []; // { feature, marker }

        // Simple color mapping by category
        const colors = {
          dataset: '#2563eb',
          site: '#16a34a',
          organization: '#7c3aed',
          event: '#e11d48',
          other: '#6b7280'
        };

        for (const feature of data.features || []) {
          if (!feature || feature.type !== 'Feature') continue;
          const coords = feature.geometry && feature.geometry.coordinates;
          if (!Array.isArray(coords) || coords.length < 2) continue;
          const [lon, lat] = coords;
          const cat = feature.properties?.category || 'other';

          const marker = L.circleMarker([lat, lon], {
            radius: 6,
            color: colors[cat] || colors.other,
            weight: 2,
            fillColor: colors[cat] || colors.other,
            fillOpacity: 0.8
          }).addTo(map);

          const name = feature.properties?.name || 'Unknown';
          const url = feature.properties?.sourceUrl;
          const popupHtml = `<strong>${name}</strong><br/>Category: ${cat}` +
            (url ? `<br/><a href="${url}" target="_blank" rel="noopener">Source</a>` : '');
          marker.bindPopup(popupHtml);

          bounds.extend([lat, lon]);
          registry.push({ feature, marker });
        }

        if (bounds.isValid()) {
          map.fitBounds(bounds.pad(0.25));
        } else {
          map.setView([0, 0], 2);
        }

        // Filtering
        const form = document.getElementById('map-filters');
        const tagInput = document.getElementById('tag-query');

        function getSelectedCategories() {
          const selected = new Set();
          if (!form) return selected;
          const inputs = form.querySelectorAll('input[name="category"]');
          inputs.forEach((el) => {
            if (el instanceof HTMLInputElement && el.checked) selected.add(el.value);
          });
          return selected;
        }

        function matchesTag(feature, query) {
          if (!query) return true;
          const q = String(query).trim().toLowerCase();
          const tags = Array.isArray(feature.properties?.tags) ? feature.properties.tags : [];
          return tags.some((t) => String(t).toLowerCase().includes(q));
        }

        function applyFilters() {
          const selected = getSelectedCategories();
          const q = tagInput instanceof HTMLInputElement ? tagInput.value : '';
          const newBounds = L.latLngBounds([]);

          for (const item of registry) {
            const cat = item.feature.properties?.category || 'other';
            const visible = selected.has(cat) && matchesTag(item.feature, q);
            const [lon, lat] = item.feature.geometry.coordinates;
            if (visible) {
              if (!map.hasLayer(item.marker)) item.marker.addTo(map);
              newBounds.extend([lat, lon]);
            } else {
              if (map.hasLayer(item.marker)) item.marker.remove();
            }
          }

          if (newBounds.isValid()) {
            map.fitBounds(newBounds.pad(0.25));
          }
        }

        form?.addEventListener('change', applyFilters);
        tagInput?.addEventListener('input', applyFilters);
      });
    </script>

    <style>
      #map {
        height: 520px;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        margin: var(--space-4) 0;
      }

      .filters {
        display: grid;
        gap: var(--space-4);
        grid-template-columns: 1fr;
        margin-bottom: var(--space-4);
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: var(--space-4) var(--space-5);
      }

      @media (min-width: 640px) {
        .filters {
          grid-template-columns: auto 1fr;
          align-items: center;
        }
      }

      .filters fieldset {
        border: none;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
        align-items: center;
      }

      .filters legend {
        font-size: var(--font-size-sm);
        font-weight: 600;
        color: var(--color-text-muted);
        margin-bottom: var(--space-2);
        width: 100%;
      }

      .filters label {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-size: var(--font-size-sm);
        cursor: pointer;
      }

      .tag-filter {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        font-size: var(--font-size-sm);
        font-weight: 600;
        color: var(--color-text-muted);
      }

      .tag-filter input {
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: var(--space-2) var(--space-3);
        font-size: var(--font-size-sm);
        background: var(--color-background);
        color: var(--color-text);
        min-width: 160px;
      }

      .marker-count {
        font-size: var(--font-size-sm);
        color: var(--color-text-muted);
        margin-top: var(--space-2);
      }
    </style>

    <p class="marker-count">{features.length} location{features.length !== 1 ? 's' : ''} plotted on the map.</p>
  </section>
</Layout>

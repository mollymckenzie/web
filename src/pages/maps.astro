---
import Layout from '@layouts/Layout.astro';
import { loadGeoMarkers } from '@lib/data/geo';
import type { GeoMarkerFeature } from '@lib/types/geo';

const collection = loadGeoMarkers();
const features = collection.features as GeoMarkerFeature[];
---

<Layout title="Community Map" description="Geographic markers for community data libraries">
  <section>
    <h1>Community Map</h1>
    <p>Interactive map of community data library locations, datasets, organizations, and events.</p>

    <form id="map-filters" class="filters" aria-label="Filter markers">
      <fieldset>
        <legend>Filter by category</legend>
        <label><input type="checkbox" name="category" value="dataset" checked /><span class="dot" style="background:#C2410C"></span> Dataset</label>
        <label><input type="checkbox" name="category" value="site" checked /><span class="dot" style="background:#166534"></span> Site</label>
        <label><input type="checkbox" name="category" value="organization" checked /><span class="dot" style="background:#B45309"></span> Organization</label>
        <label><input type="checkbox" name="category" value="event" checked /><span class="dot" style="background:#9A3412"></span> Event</label>
        <label><input type="checkbox" name="category" value="other" checked /><span class="dot" style="background:#A8927A"></span> Other</label>
      </fieldset>
      <label class="tag-filter">
        <span>Tags contains</span>
        <input type="text" id="tag-query" placeholder="e.g., transport" />
      </label>
    </form>

    <div id="map" role="region" aria-label="Community map"></div>

    <!-- Embed GeoJSON data for client-side usage -->
    <script type="application/json" id="geojson-data" set:html={JSON.stringify(collection)}></script>

    <script is:inline>
      // Dynamically inject Leaflet CSS + JS then call initMap via onload,
      // ensuring both the stylesheet and library are available before we
      // measure the container or create any Leaflet objects.
      (function loadLeaflet() {
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
        document.head.appendChild(link);

        var s = document.createElement('script');
        s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
        s.onload = initMap;
        document.head.appendChild(s);
      })();

      function initMap() {
        const map = L.map('map');
        // Base layer
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution:
            '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(map);

        // Parse embedded geojson
        const el = document.getElementById('geojson-data');
        if (!el || !el.textContent) return;
        const data = JSON.parse(el.textContent);

        // Prepare data structures
        const bounds = L.latLngBounds([]);
        const registry = []; // { feature, marker }

        // Color mapping by category — warm palette
        const colors = {
          dataset: '#C2410C',   // terracotta (primary)
          site: '#166534',      // forest green (secondary)
          organization: '#B45309', // amber (accent)
          event: '#9A3412',     // dark terracotta
          other: '#A8927A'      // warm grey
        };

        for (const feature of data.features || []) {
          if (!feature || feature.type !== 'Feature') continue;
          const coords = feature.geometry && feature.geometry.coordinates;
          if (!Array.isArray(coords) || coords.length < 2) continue;
          const [lon, lat] = coords;
          const cat = feature.properties?.category || 'other';

          const marker = L.circleMarker([lat, lon], {
            radius: 6,
            color: colors[cat] || colors.other,
            weight: 2,
            fillColor: colors[cat] || colors.other,
            fillOpacity: 0.8
          }).addTo(map);

          const name = feature.properties?.name || 'Unknown';
          const url = feature.properties?.sourceUrl;
          const popupHtml = `<strong>${name}</strong><br/>Category: ${cat}` +
            (url ? `<br/><a href="${url}" target="_blank" rel="noopener">Source</a>` : '');
          marker.bindPopup(popupHtml);

          bounds.extend([lat, lon]);
          registry.push({ feature, marker });
        }

        // Give the browser one tick after window.load to finalise any
        // remaining paint work, then tell Leaflet the true container size.
        setTimeout(() => {
          map.invalidateSize({ animate: false });
          if (bounds.isValid()) {
            map.fitBounds(bounds.pad(0.25));
          } else {
            map.setView([20, 0], 2);
          }
        }, 50);

        // Filtering
        const form = document.getElementById('map-filters');
        const tagInput = document.getElementById('tag-query');

        function getSelectedCategories() {
          const selected = new Set();
          if (!form) return selected;
          const inputs = form.querySelectorAll('input[name="category"]');
          inputs.forEach((el) => {
            if (el instanceof HTMLInputElement && el.checked) selected.add(el.value);
          });
          return selected;
        }

        function matchesTag(feature, query) {
          if (!query) return true;
          const q = String(query).trim().toLowerCase();
          const tags = Array.isArray(feature.properties?.tags) ? feature.properties.tags : [];
          return tags.some((t) => String(t).toLowerCase().includes(q));
        }

        function applyFilters() {
          const selected = getSelectedCategories();
          const q = tagInput instanceof HTMLInputElement ? tagInput.value : '';
          const newBounds = L.latLngBounds([]);

          for (const item of registry) {
            const cat = item.feature.properties?.category || 'other';
            const visible = selected.has(cat) && matchesTag(item.feature, q);
            const [lon, lat] = item.feature.geometry.coordinates;
            if (visible) {
              if (!map.hasLayer(item.marker)) item.marker.addTo(map);
              newBounds.extend([lat, lon]);
            } else {
              if (map.hasLayer(item.marker)) item.marker.remove();
            }
          }

          if (newBounds.isValid()) {
            map.fitBounds(newBounds.pad(0.25));
          }
        }

        form?.addEventListener('change', applyFilters);
        tagInput?.addEventListener('input', applyFilters);
      }

      // initMap is called via the Leaflet script's onload — no extra trigger needed.
    </script>

    <style>
      section > h1 {
        margin-bottom: var(--space-2);
      }

      section > p:first-of-type {
        color: var(--color-text-muted);
        font-size: var(--font-size-sm);
        margin-bottom: 0;
      }

      #map {
        height: 520px;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        margin: 0 0 var(--space-4);
        /* Override Leaflet's white background */
        background: var(--color-surface) !important;
      }

      /* Dark-ify Leaflet popup */
      :global(.leaflet-popup-content-wrapper) {
        background: var(--color-surface-raised) !important;
        color: var(--color-text) !important;
        border: 1px solid var(--color-border) !important;
        box-shadow: var(--shadow-md) !important;
        border-radius: var(--radius-md) !important;
      }

      :global(.leaflet-popup-tip) {
        background: var(--color-surface-raised) !important;
      }

      :global(.leaflet-popup-content a) {
        color: var(--color-primary) !important;
      }

      .filters {
        display: grid;
        gap: var(--space-4);
        grid-template-columns: 1fr;
        margin: var(--space-4) 0;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: var(--space-4) var(--space-5);
      }

      @media (min-width: 640px) {
        .filters {
          grid-template-columns: auto 1fr;
          align-items: center;
        }
      }

      .filters fieldset {
        border: none;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
        align-items: center;
      }

      .filters legend {
        font-size: var(--font-size-xs);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--color-text-dim);
        margin-bottom: var(--space-3);
        width: 100%;
      }

      .filters label {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-size: var(--font-size-sm);
        color: var(--color-text-muted);
        cursor: pointer;
        padding: var(--space-1) var(--space-2);
        border-radius: var(--radius-sm);
        transition: background 0.12s ease;
      }

      .filters label:hover {
        background: var(--color-surface-raised);
        color: var(--color-text);
      }

      .filters input[type="checkbox"] {
        accent-color: var(--color-primary);
        width: 14px;
        height: 14px;
        cursor: pointer;
      }

      .dot {
        display: inline-block;
        width: 9px;
        height: 9px;
        border-radius: 50%;
        flex-shrink: 0;
        box-shadow: 0 0 6px currentColor;
      }

      .tag-filter {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        font-size: var(--font-size-xs);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--color-text-dim);
      }

      .tag-filter input {
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: var(--space-2) var(--space-3);
        font-size: var(--font-size-sm);
        font-family: var(--font-sans);
        background: var(--color-surface-raised);
        color: var(--color-text);
        min-width: 160px;
        transition: border-color 0.15s ease;
      }

      .tag-filter input:focus {
        outline: none;
        border-color: var(--color-primary);
      }

      .marker-count {
        font-family: var(--font-mono);
        font-size: var(--font-size-xs);
        color: var(--color-text-dim);
        margin-top: var(--space-2);
      }
    </style>

    <p class="marker-count">{features.length} location{features.length !== 1 ? 's' : ''} plotted on the map.</p>
  </section>
</Layout>

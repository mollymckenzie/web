---
import Layout from '@layouts/Layout.astro';
import { loadGeoMarkers } from '@lib/data/geo';

const collection = loadGeoMarkers();
const markerCount = Array.isArray(collection.features) ? collection.features.length : 0;
---

<Layout title="Community Map" description="Geographic markers for community data libraries">
  <section>
    <h1>Community Map</h1>
    <p>Click anywhere on the map to drop a pin and see the nearest datasets for that community.</p>

    <div class="map-shell">
      <div class="map-panel" id="map-panel" aria-live="polite">
        <p class="panel-eyebrow">Community preview</p>
        <h2 id="panel-title">Drop a pin on the map</h2>
        <p id="panel-copy">We’ll surface the closest datasets in the CDL catalog for that location.</p>
        <div id="nearby-list" class="nearby-list">
          <p class="empty-copy">No pin selected yet.</p>
        </div>
      </div>

      <div id="map" role="region" aria-label="Community map"></div>
    </div>

    <!-- Embed GeoJSON data for client-side usage -->
    <script type="application/json" id="geojson-data" set:html={JSON.stringify(collection)}></script>

    <script is:inline>
      // Dynamically inject Leaflet CSS + JS then call initMap via onload,
      // ensuring both the stylesheet and library are available before we
      // measure the container or create any Leaflet objects.
      (function loadLeaflet() {
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
        document.head.appendChild(link);

        var s = document.createElement('script');
        s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
        s.onload = initMap;
        document.head.appendChild(s);
      })();

      function initMap() {
        const map = L.map('map', { scrollWheelZoom: false });
        // Base layer
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution:
            '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(map);

        // Parse embedded geojson
        const el = document.getElementById('geojson-data');
        if (!el || !el.textContent) return;
        const data = JSON.parse(el.textContent);

        // Prepare data structures
        const bounds = L.latLngBounds([]);
        const registry = []; // { feature, marker, lat, lon, title, description, url, tags }
        let userPin = null;

        // Color mapping by category — warm palette
        const colors = {
          dataset: '#C2410C',   // terracotta (primary)
          site: '#166534',      // forest green (secondary)
          organization: '#B45309', // amber (accent)
          event: '#9A3412',     // dark terracotta
          other: '#A8927A'      // warm grey
        };

        for (const feature of data.features || []) {
          if (!feature || feature.type !== 'Feature') continue;
          const coords = feature.geometry && feature.geometry.coordinates;
          if (!Array.isArray(coords) || coords.length < 2) continue;
          const [lon, lat] = coords;
          const cat = feature.properties?.category || 'other';

          const marker = L.circleMarker([lat, lon], {
            radius: 6,
            color: colors[cat] || colors.other,
            weight: 2,
            fillColor: colors[cat] || colors.other,
            fillOpacity: 0.8
          }).addTo(map);

          const name = feature.properties?.name || 'Unknown';
          const url = feature.properties?.sourceUrl;
          const popupHtml = `<strong>${name}</strong><br/>Category: ${cat}` +
            (url ? `<br/><a href="${url}" target="_blank" rel="noopener">Source</a>` : '');
          marker.bindPopup(popupHtml);

          bounds.extend([lat, lon]);
          registry.push({
            feature,
            marker,
            lat,
            lon,
            title: name,
            description: String(feature.properties?.description ?? ''),
            url,
            tags: Array.isArray(feature.properties?.tags) ? feature.properties.tags : [],
          });
        }

        // Give the browser one tick after window.load to finalise any
        // remaining paint work, then tell Leaflet the true container size.
        setTimeout(() => {
          map.invalidateSize({ animate: false });
          if (bounds.isValid()) {
            map.fitBounds(bounds.pad(0.25));
          } else {
            map.setView([20, 0], 2);
          }
        }, 50);

        function haversineDistanceKm(leftLat, leftLon, rightLat, rightLon) {
          const radiusKm = 6371;
          const toRadians = (value) => (value * Math.PI) / 180;
          const deltaLat = toRadians(rightLat - leftLat);
          const deltaLon = toRadians(rightLon - leftLon);
          const a =
            Math.sin(deltaLat / 2) * Math.sin(deltaLat / 2) +
            Math.cos(toRadians(leftLat)) * Math.cos(toRadians(rightLat)) *
            Math.sin(deltaLon / 2) * Math.sin(deltaLon / 2);
          return 2 * radiusKm * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        }

        function escapeHtml(value) {
          return String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
        }

        function renderNearbyResources(lat, lon) {
          const panelTitle = document.getElementById('panel-title');
          const panelCopy = document.getElementById('panel-copy');
          const nearbyList = document.getElementById('nearby-list');

          const nearby = registry
            .map((item) => ({
              ...item,
              distance: haversineDistanceKm(lat, lon, item.lat, item.lon),
            }))
            .sort((left, right) => left.distance - right.distance)
            .slice(0, 8);

          if (panelTitle) panelTitle.textContent = 'Nearby datasets';
          if (panelCopy) panelCopy.textContent = 'These are the closest CDL resources to your pin. Click a title to open its preview.';
          if (!nearbyList) return;

          nearbyList.innerHTML = nearby.length > 0
            ? nearby.map((item) => {
                const tagText = item.tags.slice(0, 3).join(', ');
                const titleMarkup = item.url
                  ? `<a href="${escapeHtml(item.url)}" target="_blank" rel="noopener noreferrer">${escapeHtml(item.title)}</a>`
                  : escapeHtml(item.title);
                return `<article class="nearby-item"><h3>${titleMarkup}</h3><p>${escapeHtml(item.description || 'No description provided.')}</p><p class="meta">${item.distance.toFixed(1)} km away${tagText ? ` · ${escapeHtml(tagText)}` : ''}</p></article>`;
              }).join('')
            : '<p class="empty-copy">No nearby resources found for this pin.</p>';
        }

        function placePin(lat, lon) {
          if (userPin) userPin.remove();
          userPin = L.marker([lat, lon]).addTo(map);
          renderNearbyResources(lat, lon);
        }

        map.on('click', (event) => {
          placePin(event.latlng.lat, event.latlng.lng);
        });

        if (bounds.isValid()) {
          map.fitBounds(bounds.pad(0.25));
        } else {
          map.setView([20, 0], 2);
        }
      }

      // initMap is called via the Leaflet script's onload — no extra trigger needed.
    </script>

    <style>
      section > h1 {
        margin-bottom: var(--space-2);
      }

      section > p:first-of-type {
        color: var(--color-text-muted);
        font-size: var(--font-size-sm);
        margin-bottom: 0;
      }

      .map-shell {
        position: relative;
        isolation: isolate;
      }

      #map {
        height: 560px;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        margin: 0 0 var(--space-4);
        /* Override Leaflet's white background */
        background: var(--color-surface) !important;
        position: relative;
        z-index: 0;
        overflow: hidden;
      }

      .map-panel {
        position: absolute;
        top: var(--space-4);
        right: var(--space-4);
        width: min(340px, calc(100% - var(--space-8)));
        max-height: calc(100% - var(--space-8));
        overflow: auto;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);
        box-shadow: var(--shadow-lg);
        padding: var(--space-4);
        z-index: 2;
      }

      .panel-eyebrow {
        margin: 0 0 var(--space-2);
        font-size: var(--font-size-xs);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-secondary);
      }

      .map-panel h2 {
        margin: 0 0 var(--space-2);
        font-size: var(--font-size-lg);
      }

      .map-panel p {
        margin: 0 0 var(--space-3);
        color: var(--color-text-muted);
        font-size: var(--font-size-sm);
      }

      .nearby-list {
        display: grid;
        gap: var(--space-3);
      }

      .nearby-item {
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        background: var(--color-surface);
        padding: var(--space-3);
      }

      .nearby-item h3 {
        margin: 0 0 var(--space-1);
        font-size: var(--font-size-sm);
      }

      .nearby-item a {
        color: var(--color-text);
      }

      .nearby-item p {
        margin: 0;
        color: var(--color-text-muted);
        font-size: var(--font-size-xs);
        line-height: var(--line-height-relaxed);
      }

      .nearby-item .meta {
        margin-top: var(--space-2);
        color: var(--color-text-dim);
      }

      .empty-copy {
        margin: 0;
        color: var(--color-text-dim);
        font-size: var(--font-size-sm);
      }

      /* Dark-ify Leaflet popup */
      :global(.leaflet-popup-content-wrapper) {
        background: var(--color-surface-raised) !important;
        color: var(--color-text) !important;
        border: 1px solid var(--color-border) !important;
        box-shadow: var(--shadow-md) !important;
        border-radius: var(--radius-md) !important;
      }

      :global(.leaflet-popup-tip) {
        background: var(--color-surface-raised) !important;
      }

      :global(.leaflet-popup-content a) {
        color: var(--color-primary) !important;
      }

      .marker-count {
        font-family: var(--font-mono);
        font-size: var(--font-size-xs);
        color: var(--color-text-dim);
        margin-top: var(--space-2);
      }
    </style>

    <p class="marker-count">{markerCount} location{markerCount !== 1 ? 's' : ''} plotted on the map.</p>
  </section>
</Layout>

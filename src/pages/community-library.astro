    .chip-yellow { border-color: rgba(245, 158, 11, 0.3); color: var(--color-accent); background: rgba(245, 158, 11, 0.07); }
    .chip-red { border-color: rgba(239, 68, 68, 0.3); color: #f87171; background: rgba(239, 68, 68, 0.07); }

    /* ── Section labels ─────────────── */
    .section-label {
      font-size: var(--font-size-xs);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-text-dim);

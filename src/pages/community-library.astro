    }

    .visit-btn {
      display: inline-flex;
      align-items: center;
      padding: var(--space-2) var(--space-3);
      background: rgba(99, 102, 241, 0.1);
      border: 1px solid rgba(99, 102, 241, 0.25);
      border-radius: var(--radius-md);
      color: var(--color-secondary);

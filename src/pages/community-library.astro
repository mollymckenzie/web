---
import Layout from '@layouts/Layout.astro';
import submissions from '@data/community-submissions.json';
import { withBasePath } from '@lib/paths';

// Types
interface Submission {
  id: string;
  title: string;
  description: string;
  url: string;
  category: string;
  tags: string[];
  dataThemes: string[];
  difficulty: string;
  region: string;
  submittedBy: string;
  submittedByRole: string;
  submittedAt: string;
  featured: boolean;
}

const all: Submission[] = submissions;

// Read filter params from query string
const rawCategory = Astro.url.searchParams.get('category') ?? '';
const rawTheme = Astro.url.searchParams.get('theme') ?? '';
const rawDifficulty = Astro.url.searchParams.get('difficulty') ?? '';
const rawRegion = Astro.url.searchParams.get('region') ?? '';
const rawQ = Astro.url.searchParams.get('q') ?? '';
const sort = Astro.url.searchParams.get('sort') ?? 'newest';

// Derive filter options
const allCategories = Array.from(new Set(all.map(s => s.category))).sort();
const allThemes = Array.from(new Set(all.flatMap(s => s.dataThemes))).sort();
const allDifficulties = ['beginner', 'intermediate', 'advanced'];
const allRegions = Array.from(new Set(all.map(s => s.region))).sort();

// Apply filters
const q = rawQ.trim().toLowerCase();

const filtered = all.filter(s => {
  const matchCat = rawCategory ? s.category === rawCategory : true;
  const matchTheme = rawTheme ? s.dataThemes.includes(rawTheme) : true;
  const matchDifficulty = rawDifficulty ? s.difficulty === rawDifficulty : true;
  const matchRegion = rawRegion ? s.region === rawRegion : true;
  const haystack = [s.title, s.description, ...s.tags, ...s.dataThemes, s.region].join(' ').toLowerCase();
  const matchQ = q ? haystack.includes(q) : true;
  return matchCat && matchTheme && matchDifficulty && matchRegion && matchQ;
});

// Sort
const sorted = [...filtered].sort((a, b) => {
  if (sort === 'title') return a.title.localeCompare(b.title);
  if (sort === 'difficulty') {
    const order = ['beginner', 'intermediate', 'advanced'];
    return order.indexOf(a.difficulty) - order.indexOf(b.difficulty);
  }
  // newest (default)
  return new Date(b.submittedAt).getTime() - new Date(a.submittedAt).getTime();
});

const featured = sorted.filter(s => s.featured);
const rest = sorted.filter(s => !s.featured);

const activeFilters = [
  rawCategory ? `Category: ${rawCategory}` : '',
  rawTheme ? `Theme: ${rawTheme}` : '',
  rawDifficulty ? `Difficulty: ${rawDifficulty}` : '',
  rawRegion ? `Region: ${rawRegion}` : '',
  rawQ ? `Search: "${rawQ}"` : '',
].filter(Boolean);

const clearHref = withBasePath('/community-library');

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

function difficultyColor(d: string) {
  if (d === 'beginner') return 'chip-green';
  if (d === 'intermediate') return 'chip-yellow';
  if (d === 'advanced') return 'chip-red';
  return '';
}

const categoryIcons: Record<string, string> = {
  dataset: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
  tool: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  guide: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
  paper: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
};
---

<Layout
  title="Community Library"
  description="Resources contributed by practitioners, teachers, researchers, and community members worldwide."
>
  <section class="cl-shell">

    <!-- Page header -->
    <header class="cl-header">
      <div class="cl-header-text">
        <div class="eyebrow">Community Contributed</div>
        <h1>Community Library</h1>
        <p class="cl-desc">
          Resources discovered and shared by practitioners, researchers, teachers, and community members from around the world. For a concrete implementation, explore the <a href={withBasePath('/example-community-library')}>Example Community Library (Knox County)</a>, which complements the <a href={withBasePath('/complete-catalog')}>Complete Catalog</a> with locally relevant datasets and tools.
        </p>
      </div>
      <a href={withBasePath('/submit')} class="button submit-cta">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Submit a Resource
      </a>
    </header>

    <!-- Stats bar -->
    <div class="stats-bar" aria-label="Library statistics">
      <div class="stat">
        <span class="stat-n">{all.length}</span>
        <span class="stat-l">Total Resources</span>
      </div>
      <div class="stat">
        <span class="stat-n">{all.filter(s => s.category === 'dataset').length}</span>
        <span class="stat-l">Datasets</span>
      </div>
      <div class="stat">
        <span class="stat-n">{allThemes.length}</span>
        <span class="stat-l">Themes</span>
      </div>
      <div class="stat">
        <span class="stat-n">{Array.from(new Set(all.map(s => s.region))).length}</span>
        <span class="stat-l">Regions</span>
      </div>
    </div>

    <div class="cl-body">
      <!-- Sidebar filters -->
      <aside class="cl-sidebar" id="cl-sidebar">
        <div class="sidebar-head">
          <h2>Filters</h2>
          <button class="sidebar-close" id="cl-sidebar-close" aria-label="Close filters">✕</button>
        </div>

        <form method="get" action={withBasePath('/community-library')} class="cl-filters">
          <div class="filter-field">
            <label for="cl-q">Search</label>
            <input type="search" id="cl-q" name="q" value={rawQ} placeholder="Title, tags, region…" />
          </div>

          <div class="filter-field">
            <label for="cl-cat">Category</label>
            <select id="cl-cat" name="category">
              <option value="">All categories</option>
              {allCategories.map(c => (
                <option value={c} selected={rawCategory === c}>{c.charAt(0).toUpperCase() + c.slice(1)}</option>
              ))}
            </select>
          </div>

          <div class="filter-field">
            <label for="cl-theme">Data Theme</label>
            <select id="cl-theme" name="theme">
              <option value="">All themes</option>
              {allThemes.map(t => (
                <option value={t} selected={rawTheme === t}>{t}</option>
              ))}
            </select>
          </div>

          <div class="filter-field">
            <label for="cl-diff">Difficulty</label>
            <select id="cl-diff" name="difficulty">
              <option value="">Any difficulty</option>
              {allDifficulties.map(d => (
                <option value={d} selected={rawDifficulty === d}>{d.charAt(0).toUpperCase() + d.slice(1)}</option>
              ))}
            </select>
          </div>

          <div class="filter-field">
            <label for="cl-region">Region</label>
            <select id="cl-region" name="region">
              <option value="">All regions</option>
              {allRegions.map(r => (
                <option value={r} selected={rawRegion === r}>{r}</option>
              ))}
            </select>
          </div>

          <div class="filter-field">
            <label for="cl-sort">Sort by</label>
            <select id="cl-sort" name="sort">
              <option value="newest" selected={sort === 'newest'}>Newest first</option>
              <option value="title" selected={sort === 'title'}>A–Z</option>
              <option value="difficulty" selected={sort === 'difficulty'}>Easiest first</option>
            </select>
          </div>

          <div class="filter-actions">
            <button type="submit" class="button">Apply</button>
            <a href={clearHref} class="reset-link">Reset</a>
          </div>
        </form>

        <!-- Category breakdown -->
        <div class="type-panel">
          <h3>By Category</h3>
          <ul>
            {allCategories.map(c => (
              <li>
                <span>{c.charAt(0).toUpperCase() + c.slice(1)}</span>
                <strong>{all.filter(s => s.category === c).length}</strong>
              </li>
            ))}
          </ul>
        </div>
      </aside>

      <!-- Main content -->
      <div class="cl-content">
        <button class="mobile-filter-btn" id="cl-filter-btn" aria-expanded="false" aria-controls="cl-sidebar">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
          Filters
        </button>

        <!-- Active filters -->
        {activeFilters.length > 0 && (
          <div class="active-filters" aria-label="Active filters">
            {activeFilters.map(f => <span class="chip">{f}</span>)}
            <a href={clearHref} class="chip chip-clear">Clear all ✕</a>
          </div>
        )}

        <!-- Results count -->
        <div class="results-bar">
          <p><strong>{sorted.length}</strong> {sorted.length === 1 ? 'resource' : 'resources'} {activeFilters.length > 0 ? 'match your filters' : 'in the community library'}</p>
        </div>

        <!-- Featured resources -->
        {featured.length > 0 && (
          <section class="featured-section">
            <h2 class="section-label">Featured</h2>
            <div class="featured-grid">
              {featured.map(s => (
                <article class="featured-card">
                  <div class="card-top">
                    <div class="card-category" set:html={categoryIcons[s.category] ?? ''} />
                    <span class="chip">{s.category}</span>
                    {s.difficulty && <span class={`chip ${difficultyColor(s.difficulty)}`}>{s.difficulty}</span>}
                  </div>
                  <h3>
                    <a href={s.url} target="_blank" rel="noopener noreferrer">{s.title}</a>
                  </h3>
                  <p>{s.description}</p>
                  <div class="card-meta">
                    <span class="meta-region">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.25 8 12 8 12s8-6.75 8-12a8 8 0 0 0-8-8z"/></svg>
                      {s.region}
                    </span>
                    <span class="meta-submitter">by {s.submittedBy}</span>
                  </div>
                  <div class="chips">
                    {s.dataThemes.slice(0, 3).map(t => <span class="chip chip-theme">{t}</span>)}
                  </div>
                </article>
              ))}
            </div>
          </section>
        )}

        <!-- All resources -->
        {rest.length > 0 && (
          <section class="results-section">
            {featured.length > 0 && <h2 class="section-label">All Resources</h2>}
            <div class="results-list">
              {rest.map(s => (
                <article class="result-card">
                  <div class="result-main">
                    <div class="card-top">
                      <div class="card-category" set:html={categoryIcons[s.category] ?? ''} />
                      <span class="chip">{s.category}</span>
                      {s.difficulty && <span class={`chip ${difficultyColor(s.difficulty)}`}>{s.difficulty}</span>}
                    </div>
                    <h3>
                      <a href={s.url} target="_blank" rel="noopener noreferrer">{s.title}</a>
                    </h3>
                    <p>{s.description}</p>
                    <div class="chips">
                      {s.dataThemes.slice(0, 3).map(t => <span class="chip chip-theme">{t}</span>)}
                      {s.tags.slice(0, 2).map(t => <span class="chip">{t}</span>)}
                    </div>
                  </div>
                  <aside class="result-side">
                    <div class="side-item">
                      <span class="side-label">Region</span>
                      <span class="side-value">{s.region}</span>
                    </div>
                    <div class="side-item">
                      <span class="side-label">Added</span>
                      <span class="side-value">{formatDate(s.submittedAt)}</span>
                    </div>
                    <div class="side-item">
                      <span class="side-label">By</span>
                      <span class="side-value">{s.submittedBy}</span>
                    </div>
                    <a href={s.url} target="_blank" rel="noopener noreferrer" class="visit-btn">
                      Visit resource ↗
                    </a>
                  </aside>
                </article>
              ))}
            </div>
          </section>
        )}

        {sorted.length === 0 && (
          <div class="empty-state">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <h3>No resources match these filters</h3>
            <p>Try adjusting your search or <a href={clearHref}>clear all filters</a>.</p>
          </div>
        )}

      </div>
    </div>
  </section>

  <script>
    // Mobile sidebar toggle
    const filterBtn = document.getElementById('cl-filter-btn');
    const sidebar = document.getElementById('cl-sidebar');
    const sidebarClose = document.getElementById('cl-sidebar-close');

    filterBtn?.addEventListener('click', () => {
      sidebar?.classList.add('open');
      filterBtn.setAttribute('aria-expanded', 'true');
    });
    sidebarClose?.addEventListener('click', () => {
      sidebar?.classList.remove('open');
      filterBtn?.setAttribute('aria-expanded', 'false');
    });
  </script>

  <style>
    /* ── Shell ──────────────────────────── */
    .cl-shell {
      display: grid;
      gap: var(--space-8);
    }

    /* ── Header ──────────────────────────── */
    .cl-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--space-6);
      flex-wrap: wrap;
    }

    .cl-header-text { flex: 1; min-width: 280px; }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-1) var(--space-3);
      background: rgba(99, 102, 241, 0.1);
      border: 1px solid rgba(99, 102, 241, 0.25);
      border-radius: 999px;
      font-size: var(--font-size-xs);
      font-weight: 600;
      color: var(--color-secondary);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: var(--space-4);
    }

    .cl-header h1 { margin-bottom: var(--space-3); }

    .cl-desc {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-lg);
      line-height: var(--line-height-relaxed);
      max-width: 65ch;
    }

    .cl-desc a { color: var(--color-primary); }

    .submit-cta { flex-shrink: 0; }

    /* ── Stats bar ───────────────────────── */
    .stats-bar {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1px;
      background: var(--color-border);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      overflow: hidden;
    }

    @media (min-width: 640px) {
      .stats-bar { grid-template-columns: repeat(4, 1fr); }
    }

    .stat {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: var(--space-5) var(--space-4);
      gap: var(--space-1);
      background: var(--color-surface);
      text-align: center;
    }

    .stat-n {
      font-family: var(--font-mono);
      font-size: var(--font-size-2xl);
      font-weight: 500;
      color: var(--color-secondary);
      line-height: 1;
      letter-spacing: -0.03em;
    }

    .stat-l {
      font-size: var(--font-size-xs);
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-weight: 600;
    }

    /* ── Body layout ─────────────────────── */
    .cl-body {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    @media (min-width: 1024px) {
      .cl-body { grid-template-columns: minmax(240px, 270px) 1fr; align-items: start; }
    }

    /* ── Mobile filter toggle ─────────── */
    .mobile-filter-btn {
      display: none;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-2) var(--space-4);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 999px;
      font-size: var(--font-size-sm);
      font-weight: 600;
      color: var(--color-text-muted);
      cursor: pointer;
      margin-bottom: var(--space-4);
      transition: all 0.15s ease;
    }

    .mobile-filter-btn:hover {
      border-color: var(--color-secondary);
      color: var(--color-secondary);
      background: rgba(99, 102, 241, 0.08);
      box-shadow: none;
      transform: none;
    }

    @media (max-width: 1023px) {
      .mobile-filter-btn { display: inline-flex; }
      .sidebar-close { display: inline-flex; align-items: center; }

      .cl-sidebar {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        z-index: 200;
        border-radius: 0;
        overflow-y: auto;
        border: none;
        padding-top: var(--space-8);
      }

      .cl-sidebar.open { display: grid; }
    }

    /* ── Sidebar ──────────────────────── */
    .cl-sidebar {
      position: sticky;
      top: calc(60px + var(--space-6));
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-surface);
      padding: var(--space-5);
      display: grid;
      gap: var(--space-5);
    }

    .sidebar-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .cl-sidebar h2 {
      margin: 0;
      font-size: var(--font-size-lg);
    }

    .sidebar-close {
      display: none;
      background: none;
      border: 1px solid var(--color-border);
      cursor: pointer;
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
      padding: var(--space-1) var(--space-3);
      border-radius: var(--radius-md);
      transition: all 0.15s ease;
    }

    .cl-filters {
      display: grid;
      gap: var(--space-4);
    }

    .filter-field {
      display: grid;
      gap: var(--space-2);
    }

    .filter-field label {
      font-size: var(--font-size-xs);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--color-text-dim);
    }

    .filter-field input,
    .filter-field select {
      width: 100%;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-2) var(--space-3);
      background: var(--color-surface-raised);
      color: var(--color-text);
      font-family: var(--font-sans);
      font-size: var(--font-size-sm);
      transition: border-color 0.15s ease;
      appearance: none;
      -webkit-appearance: none;
    }

    .filter-field input:focus,
    .filter-field select:focus {
      outline: none;
      border-color: var(--color-secondary);
    }

    .filter-actions {
      display: flex;
      align-items: center;
      gap: var(--space-3);
    }

    .filter-actions .button {
      padding: var(--space-2) var(--space-4);
      font-size: var(--font-size-sm);
      background: var(--color-secondary);
    }

    .filter-actions .button:hover {
      background: #4f46e5;
      box-shadow: var(--shadow-glow-secondary);
    }

    .reset-link {
      display: inline-flex;
      align-items: center;
      padding: var(--space-2) var(--space-3);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
      font-weight: 500;
      text-decoration: none;
      transition: all 0.15s ease;
    }

    .reset-link:hover {
      border-color: var(--color-secondary);
      color: var(--color-secondary);
      text-decoration: none;
    }

    .type-panel {
      border-top: 1px solid var(--color-border);
      padding-top: var(--space-4);
    }

    .type-panel h3 {
      margin: 0 0 var(--space-3);
      font-size: var(--font-size-xs);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--color-text-dim);
    }

    .type-panel ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: var(--space-2);
    }

    .type-panel li {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
    }

    .type-panel li strong {
      font-family: var(--font-mono);
      font-size: var(--font-size-xs);
      color: var(--color-secondary);
    }

    /* ── Content ──────────────────────── */
    .cl-content { display: grid; gap: var(--space-5); }

    .active-filters {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .chip-clear {
      border-color: rgba(245, 158, 11, 0.4);
      color: var(--color-accent);
      background: rgba(245, 158, 11, 0.07);
      text-decoration: none;
    }

    .results-bar {
      display: flex;
      align-items: center;
      padding: var(--space-3) 0;
      border-bottom: 1px solid var(--color-border);
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
    }

    .results-bar strong { color: var(--color-text); }
    .results-bar p { margin: 0; }

    /* ── Chips ──────────────────────── */
    .chips { display: flex; flex-wrap: wrap; gap: var(--space-2); }

    .chip {
      display: inline-flex;
      align-items: center;
      padding: 2px var(--space-2);
      border-radius: var(--radius-sm);
      border: 1px solid var(--color-border);
      font-size: var(--font-size-xs);
      font-weight: 500;

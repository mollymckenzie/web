---
import Layout from '@layouts/Layout.astro';
import { withBasePath } from '@lib/paths';
---

<Layout
  title="Data Resources"
  description="Entry points for submitting data resources, lesson plans, and community activities."
>
  <section class="data-resources-shell">
    <header class="page-header">
      <p class="eyebrow">Data Resources</p>
      <h1>Find the right path for data work.</h1>
      <p class="intro">
        Use this section to suggest resources, explore lesson plans, and follow upcoming community activities.
      </p>
    </header>

    <div class="resource-grid">
      <article class="resource-card" id="submit">
        <div class="card-icon">01</div>
        <h2>Suggest a Data Resource</h2>
        <p>Submit a dataset, tool, guide, or paper for review and inclusion in the collection.</p>
        <a href={withBasePath('/submit')} class="button">Go to submission form</a>
      </article>

      <article class="resource-card" id="lesson-plans">
        <div class="card-icon">02</div>
        <h2>Lesson Plans &amp; Resources</h2>
        <p>Curated classroom-ready materials are planned for next summer.</p>
        <span class="status-pill">Coming next summer</span>
      </article>

      <article class="resource-card" id="community-activities">
        <div class="card-icon">03</div>
        <h2>Community Activities</h2>
        <p>Guides and workshop materials for community sessions are planned for a later release.</p>
        <span class="status-pill">Coming in two summers</span>
      </article>
    </div>
  </section>

  <style>
    .data-resources-shell {
      display: grid;
      gap: var(--space-8);
    }

    .page-header {
      display: grid;
      gap: var(--space-3);
      max-width: 70ch;
    }

    .eyebrow {
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: var(--font-size-xs);
      font-weight: 700;
      color: var(--color-secondary);
    }

    .page-header h1 {
      margin: 0;
      font-size: clamp(2.25rem, 4vw, 3.5rem);
    }

    .intro {
      margin: 0;
      max-width: 62ch;
      color: var(--color-text-muted);
      font-size: var(--font-size-lg);
    }

    .resource-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    @media (min-width: 900px) {
      .resource-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    .resource-card {
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      border-radius: var(--radius-xl);
      padding: var(--space-6);
      box-shadow: var(--shadow-sm);
      display: grid;
      gap: var(--space-4);
      align-content: start;
    }

    .card-icon {
      width: 3rem;
      height: 3rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius-lg);
      background: var(--color-primary-glow);
      color: var(--color-primary);
      font-weight: 700;
      letter-spacing: 0.06em;
    }

    .resource-card h2 {
      margin: 0;
      font-size: var(--font-size-2xl);
    }

    .resource-card p {
      margin: 0;
      color: var(--color-text-muted);
    }

    .status-pill {
      justify-self: start;
      padding: 0.4rem 0.75rem;
      border-radius: 999px;
      background: var(--color-surface-raised);
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
      font-weight: 600;
    }
  </style>
</Layout>
---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { canAudienceAccess, extractPedagogicalTags, type AudienceRole } from '@lib/data/libraryAccess';
import { withBasePath } from '@lib/paths';

const resources = await getCollection('master-library');

// Non-audience filters can still be read server-side (works in dev mode SSR,
// and client-side JS handles audience; for static builds everything is client-side)
const selectedTheme = (Astro.url.searchParams.get('theme') ?? '').trim();
const selectedPedagogicalTag = (Astro.url.searchParams.get('pedagogicalTag') ?? '').trim();
const query = (Astro.url.searchParams.get('q') ?? '').trim();
const sort = Astro.url.searchParams.get('sort') ?? 'updated';

const searchQuery = query.toLowerCase();

// All unique themes (audience-independent for static compatibility)
const allThemes = [...new Set(
  resources.flatMap(r => r.data.dataThemes.length > 0 ? r.data.dataThemes : r.data.tags)
)].sort((a, b) => a.localeCompare(b));

const allPedagogicalTags = extractPedagogicalTags(resources);

// Apply non-audience filters server-side (theme, search, sort)
const filteredResources = resources.filter((resource) => {
  const themes = resource.data.dataThemes.length > 0 ? resource.data.dataThemes : resource.data.tags;
  const matchesTheme = selectedTheme ? themes.includes(selectedTheme) : true;
  const matchesPedagogicalTag = selectedPedagogicalTag
    ? resource.data.pedagogicalTags.includes(selectedPedagogicalTag)
    : true;
  const haystack = [resource.data.title, resource.data.description, ...themes, ...resource.data.tags]
    .join(' ')
    .toLowerCase();
  const matchesSearch = searchQuery ? haystack.includes(searchQuery) : true;
  return matchesTheme && matchesPedagogicalTag && matchesSearch;
});

const sortedResources = [...filteredResources].sort((l, r) => {
  if (sort === 'title') return l.data.title.localeCompare(r.data.title);
  const lt = l.data.publishedDate ? new Date(l.data.publishedDate).getTime() : 0;
  const rt = r.data.publishedDate ? new Date(r.data.publishedDate).getTime() : 0;
  return rt - lt;
});

// Compute which audiences can access each resource (for data attributes)
function getResourceAudiences(resource: (typeof resources)[number]): string {
  const audiences: string[] = [];
  if (canAudienceAccess(resource, 'teacher')) audiences.push('teacher');
  if (canAudienceAccess(resource, 'student')) audiences.push('student');
  if (canAudienceAccess(resource, 'community')) audiences.push('community');
  return audiences.join(' ');
}

const clearFiltersHref = withBasePath('/complete-catalog');
const activeFilters = [
  selectedTheme ? `Theme: ${selectedTheme}` : '',
  selectedPedagogicalTag ? `Pedagogical Tag: ${selectedPedagogicalTag}` : '',
  query ? `Search: ${query}` : '',
].filter(Boolean);

const teacherViewHref = withBasePath('/complete-catalog?audience=teacher');
const studentViewHref = withBasePath('/complete-catalog?audience=student');
const communityViewHref = withBasePath('/complete-catalog?audience=community');

function formatDate(date: Date | undefined): string {
  if (!date) return 'Not specified';
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title="Complete Catalog" description="All curated resources in the CDL complete catalog">
  <section class="library-page">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <h2>Filters</h2>
        <button class="sidebar-close" id="sidebar-close" aria-label="Close filters">✕</button>
      </div>
      <form method="get" action={withBasePath('/complete-catalog')} class="filters-form">
        <!-- audience is set by JS before submit so the URL preserves the selected view -->
        <input type="hidden" name="audience" id="hidden-audience" value="community" />

        <label>
          <span>Search</span>
          <input type="search" name="q" value={query} placeholder="Search title, description, or themes" />
        </label>

        <label>
          <span>Theme</span>
          <select name="theme">
            <option value="">All themes</option>
            {allThemes.map((theme) => (
              <option value={theme} selected={selectedTheme === theme}>{theme}</option>
            ))}
          </select>
        </label>

        <!-- Pedagogical tag filter: always rendered, shown/hidden by JS based on audience -->
        <label id="pedagogical-tag-filter" style="display:none">
          <span>Pedagogical Tag</span>
          <select name="pedagogicalTag">
            <option value="">All pedagogical tags</option>
            {allPedagogicalTags.map((tag) => (
              <option value={tag} selected={selectedPedagogicalTag === tag}>{tag}</option>
            ))}
          </select>
        </label>

        <label>
          <span>Sort</span>
          <select name="sort">
            <option value="updated" selected={sort === 'updated'}>Most recent</option>
            <option value="title" selected={sort === 'title'}>A-Z</option>
          </select>
        </label>

        <div class="filter-actions">
          <button type="submit" class="button">Apply</button>
          <a href={clearFiltersHref} class="reset-link">Reset</a>
        </div>
      </form>
    </aside>

    <div class="content">
      <button class="mobile-filter-btn" id="mobile-filter-btn" aria-expanded="false" aria-controls="sidebar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
        Filters
      </button>

      <!-- View guide cards: clicking switches audience (client-side, no reload) -->
      <section class="view-guide" aria-label="Audience views">
        <a href={teacherViewHref} data-audience="teacher" class="view-card view-card-teacher">
          <h2>Teacher View</h2>
          <p>Shows pedagogical tags and the full dataset set for classroom planning.</p>
        </a>
        <a href={studentViewHref} data-audience="student" class="view-card view-card-student">
          <h2>Student View</h2>
          <p>Shows the student-safe catalog with sensitive datasets removed.</p>
        </a>
        <a href={communityViewHref} data-audience="community" class="view-card view-card-community">
          <h2>Communities View</h2>
          <p>Shows the full catalog with every dataset included.</p>
        </a>
      </section>

      <header class="content-header">
        <div>
          <h1>Complete Catalog</h1>
          <p id="audience-label-text">
            Showing <strong>Community Member</strong> view.
            Switch views to compare audience-specific filters.
          </p>
        </div>
      </header>

      <div class="results-head">
        <p id="resource-count"><strong>{sortedResources.length}</strong> resources</p>
        <div class="results-head-right">
          {activeFilters.length > 0 && <a href={clearFiltersHref}>Clear filters</a>}
          <div class="view-toggle" role="group" aria-label="View mode">
            <button class="view-btn active" data-view="list" title="List view" aria-pressed="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            </button>
            <button class="view-btn" data-view="grid" title="Grid view" aria-pressed="false">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            </button>
            <button class="view-btn" data-view="table" title="Table view" aria-pressed="false">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="9" x2="9" y2="21"/></svg>
            </button>
          </div>
        </div>
      </div>

      {activeFilters.length > 0 && (
        <div class="active-filters" aria-label="Active filters">
          {activeFilters.map((item) => (
            <span class="chip">{item}</span>
          ))}
        </div>
      )}

      <!-- data-audience="community" is the default; JS updates it on load -->
      <section class="results" id="results-section" data-view="list" data-audience="community">
        <h2>All Resources</h2>

        {sortedResources.length === 0 ? (
          <article class="result-card empty"><p>No resources match your current filter combination.</p></article>
        ) : (
          <>
            {/* Card / Grid view */}
            <div class="cards-view">
              {sortedResources.map((resource) => {
                const themes = resource.data.dataThemes.length > 0 ? resource.data.dataThemes : resource.data.tags;
                const previewHref = withBasePath(`/data-preview?entry=${encodeURIComponent(resource.id)}&audience=AUDIENCE_PLACEHOLDER`);
                const resourceAudiences = getResourceAudiences(resource);
                return (
                  <article class="result-card" data-audiences={resourceAudiences}>
                    <div class="result-main">
                      <h3>
                        <a href={previewHref} class="preview-link">{resource.data.title}</a>
                      </h3>
                      <p>{resource.data.description}</p>
                      <div class="chips">
                        {themes.slice(0, 3).map((theme) => (
                          <span class="chip chip-theme">{theme}</span>
                        ))}
                        {resource.data.pedagogicalTags.slice(0, 2).map((tag) => (
                          <span class="chip chip-pedagogical">{tag}</span>
                        ))}
                      </div>
                      <p class="meta-line">Updated {formatDate(resource.data.publishedDate)}</p>
                    </div>
                  </article>
                );
              })}
            </div>

            {/* Table view */}
            <div class="table-view">
              <table>
                <thead>
                  <tr>
                    <th>Title</th>
                    <th>Themes</th>
                    <th class="th-pedagogical">Pedagogical Tags</th>
                    <th>Updated</th>
                  </tr>
                </thead>
                <tbody>
                  {sortedResources.map((resource) => {
                    const themes = resource.data.dataThemes.length > 0 ? resource.data.dataThemes : resource.data.tags;
                    const previewHref = withBasePath(`/data-preview?entry=${encodeURIComponent(resource.id)}&audience=AUDIENCE_PLACEHOLDER`);
                    const resourceAudiences = getResourceAudiences(resource);
                    return (
                      <tr data-audiences={resourceAudiences}>
                        <td class="td-title">
                          <a href={previewHref} class="preview-link">{resource.data.title}</a>
                        </td>
                        <td>
                          <div class="chips">
                            {themes.slice(0, 2).map((theme) => <span class="chip chip-theme">{theme}</span>)}
                          </div>
                        </td>
                        <td class="td-pedagogical">
                          <div class="chips">
                            {resource.data.pedagogicalTags.slice(0, 2).map((tag) => (
                              <span class="chip chip-pedagogical">{tag}</span>
                            ))}
                          </div>
                        </td>
                        <td class="td-meta">{formatDate(resource.data.publishedDate)}</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </>
        )}
      </section>
    </div>
  </section>

  <script>
    // ── Mobile sidebar toggle ──────────────────────────────────────────
    const mobileFilterBtn = document.getElementById('mobile-filter-btn');
    const sidebarEl = document.getElementById('sidebar');
    const sidebarClose = document.getElementById('sidebar-close');

    function openSidebar() {
      sidebarEl?.classList.add('open');
      mobileFilterBtn?.setAttribute('aria-expanded', 'true');
    }
    function closeSidebar() {
      sidebarEl?.classList.remove('open');
      mobileFilterBtn?.setAttribute('aria-expanded', 'false');
    }

    mobileFilterBtn?.addEventListener('click', openSidebar);
    sidebarClose?.addEventListener('click', closeSidebar);

    // ── View toggle (list / grid / table) ─────────────────────────────
    const section = document.getElementById('results-section');
    const viewButtons = document.querySelectorAll('.view-btn');

    const savedView = localStorage.getItem('ml-view') ?? 'list';
    applyView(savedView);

    viewButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const view = (btn as HTMLElement).dataset.view ?? 'list';
        applyView(view);
        localStorage.setItem('ml-view', view);
      });
    });

    function applyView(view: string) {
      if (!section) return;
      section.dataset.view = view;
      viewButtons.forEach((btn) => {
        const isActive = (btn as HTMLElement).dataset.view === view;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', String(isActive));
      });
    }

    // ── Audience switching (client-side, static-build compatible) ─────
    const audienceLabelEl = document.getElementById('audience-label-text');
    const resourceCountEl = document.getElementById('resource-count');
    const pedagogicalFilterEl = document.getElementById('pedagogical-tag-filter');
    const hiddenAudienceInput = document.getElementById('hidden-audience') as HTMLInputElement | null;

    const audienceDescriptions: Record<string, string> = {
      teacher: 'Teacher view — pedagogical tags are available in this view.',
      student: 'Student view — sensitive datasets are excluded.',
      community: 'Communities view — complete, unfiltered catalog showing all datasets.',
    };
    const audienceDisplayNames: Record<string, string> = {
      teacher: 'Teacher',
      student: 'Student',
      community: 'Community Member',
    };

    function applyAudience(audience: string) {
      if (!section) return;

      // Update data-attribute (CSS handles card show/hide)
      section.dataset.audience = audience;

      // Update active state on view-guide cards
      document.querySelectorAll<HTMLElement>('.view-card[data-audience]').forEach((card) => {
        card.classList.toggle('active', card.dataset.audience === audience);
      });

      // Update active state on audience-switch pills
      document.querySelectorAll<HTMLElement>('.audience-switch [data-audience]').forEach((link) => {
        link.classList.toggle('active', link.dataset.audience === audience);
      });

      // Show/hide pedagogical tag filter
      if (pedagogicalFilterEl) {
        (pedagogicalFilterEl as HTMLElement).style.display = audience === 'teacher' ? '' : 'none';
      }

      // Update audience label paragraph
      if (audienceLabelEl) {
        const name = audienceDisplayNames[audience] ?? 'Community Member';
        const desc = audienceDescriptions[audience] ?? '';
        audienceLabelEl.innerHTML = `Showing <strong>${name}</strong> view. ${desc}`;
      }

      // Update hidden form input so form submissions preserve the audience
      if (hiddenAudienceInput) hiddenAudienceInput.value = audience;

      // Update preview link hrefs so the data-preview page knows the audience
      document.querySelectorAll<HTMLAnchorElement>('.preview-link').forEach((link) => {
        link.href = link.href.replace(/audience=[^&]+/, `audience=${audience}`);
      });

      // Update resource count
      if (resourceCountEl) {
        const allCards = section.querySelectorAll<HTMLElement>('.result-card:not(.empty)');
        let count = 0;
        allCards.forEach((card) => {
          const audiences = (card.dataset.audiences ?? '').split(' ');
          if (audiences.includes(audience)) count++;
        });
        resourceCountEl.innerHTML = `<strong>${count}</strong> resources`;
      }
    }

    // Intercept audience link/card clicks — update URL via pushState, no reload
    document.querySelectorAll<HTMLElement>('[data-audience].view-card, .audience-switch [data-audience]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        const audience = el.dataset.audience ?? 'community';
        const url = new URL(window.location.href);
        url.searchParams.set('audience', audience);
        history.pushState({ audience }, '', url.toString());
        applyAudience(audience);
      });
    });

    // Handle browser back/forward
    window.addEventListener('popstate', () => {
      const audience = new URLSearchParams(window.location.search).get('audience') ?? 'community';
      applyAudience(audience);
    });

    // Apply audience on page load from URL
    const initialAudience = new URLSearchParams(window.location.search).get('audience') ?? 'community';
    applyAudience(initialAudience);
  </script>

  <style>
    /* ── Layout ─────────────────────────── */
    .library-page {
      display: grid;
      gap: var(--space-6);
      grid-template-columns: 1fr;
    }

    @media (min-width: 1024px) {
      .library-page {
        grid-template-columns: minmax(260px, 290px) 1fr;
        align-items: start;
      }
    }

    /* ── Mobile filter toggle ─────────── */
    .mobile-filter-btn {
      display: none;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-2) var(--space-4);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 999px;
      font-size: var(--font-size-sm);
      font-weight: 600;
      color: var(--color-text-muted);
      cursor: pointer;
      margin-bottom: var(--space-4);
      transition: all 0.15s ease;
    }

    .mobile-filter-btn:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
      background: var(--color-primary-glow);
      box-shadow: none;
      transform: none;
    }

    .sidebar-close {
      display: none;
      background: none;
      border: 1px solid var(--color-border);
      cursor: pointer;
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
      padding: var(--space-1) var(--space-3);
      border-radius: var(--radius-md);
      transition: all 0.15s ease;
      transform: none;
    }

    .sidebar-close:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
      box-shadow: none;
    }

    /* ── Sidebar ─────────────────────── */
    .sidebar-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .sidebar {
      position: sticky;
      top: calc(60px + var(--space-8));
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-surface);
      padding: var(--space-5);
      display: grid;
      gap: var(--space-5);
    }

    @media (max-width: 1023px) {
      .mobile-filter-btn { display: inline-flex; }
      .sidebar-close { display: inline-flex; align-items: center; }

      .sidebar {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        z-index: 200;
        border-radius: 0;
        overflow-y: auto;
        border: none;
        padding-top: var(--space-8);
      }

      .sidebar.open { display: grid; }
    }

    .sidebar h2 {
      margin: 0;
      font-size: var(--font-size-lg);
      color: var(--color-text);
    }

    .filters-form {
      display: grid;
      gap: var(--space-4);
    }

    .filters-form label {
      display: grid;
      gap: var(--space-2);
    }

    .filters-form span {
      font-size: var(--font-size-xs);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--color-text-dim);
    }

    .filters-form input,
    .filters-form select {
      width: 100%;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-2) var(--space-3);
      background: var(--color-surface-raised);
      color: var(--color-text);
      font-family: var(--font-sans);
      font-size: var(--font-size-sm);
      transition: border-color 0.15s ease;
      appearance: none;
      -webkit-appearance: none;
    }

    .filters-form input:focus,
    .filters-form select:focus {
      outline: none;
      border-color: var(--color-primary);
    }

    .filter-actions {
      display: flex;
      align-items: center;
      gap: var(--space-3);
    }

    .filter-actions .button {
      padding: var(--space-2) var(--space-4);
      font-size: var(--font-size-sm);
      border-radius: var(--radius-md);
    }

    .reset-link {
      display: inline-flex;
      align-items: center;
      padding: var(--space-2) var(--space-3);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
      font-weight: 500;
      text-decoration: none;
      transition: all 0.15s ease;
    }

    .reset-link:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
      background: var(--color-primary-glow);
      text-decoration: none;
    }

    /* ── Content area ────────────────── */
    .content {
      display: grid;
      gap: var(--space-5);
    }

    .content-header {
      display: grid;
      gap: var(--space-4);
    }

    .content-header h1 {
      margin-bottom: var(--space-2);
      font-size: clamp(var(--font-size-2xl), 2.5vw, var(--font-size-4xl));
    }

    .content-header p {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
    }

    /* ── View guide cards ────────────── */
    .view-guide {
      display: grid;
      gap: var(--space-3);
      grid-template-columns: 1fr;
    }

    @media (min-width: 900px) {
      .view-guide {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .view-card {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-surface);
      padding: var(--space-4);
      display: grid;
      gap: var(--space-2);
      color: inherit;
      text-decoration: none;
      cursor: pointer;
      transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
    }

    .view-card:hover {
      text-decoration: none;
      transform: translateY(-1px);
      box-shadow: var(--shadow-sm);
    }

    .view-card.active {
      border-width: 2px;
    }

    .view-card h2 {
      margin: 0;
      font-size: var(--font-size-sm);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .view-card p {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
      line-height: var(--line-height-relaxed);
    }

    .view-card-teacher {
      border-color: rgba(14, 114, 101, 0.25);
      background: rgba(14, 114, 101, 0.05);
    }

    .view-card-student {
      border-color: rgba(21, 94, 117, 0.25);
      background: rgba(21, 94, 117, 0.05);
    }

    .view-card-community {
      border-color: rgba(26, 107, 69, 0.25);
      background: rgba(26, 107, 69, 0.05);
    }

    /* ── Audience switch pills ───────── */
    .audience-switch {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .audience-switch a {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-2) var(--space-4);
      font-size: var(--font-size-sm);
      font-weight: 500;
      color: var(--color-text-muted);
      text-decoration: none;
      transition: all 0.15s ease;
      background: transparent;
    }

    .audience-switch a:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
      background: var(--color-primary-glow);
      text-decoration: none;
    }

    .audience-switch a.active {
      background: var(--color-primary);
      border-color: var(--color-primary);
      color: #ffffff;
      font-weight: 600;
    }

    .audience-switch a.active:hover {
      background: var(--color-primary-dark);
      border-color: var(--color-primary-dark);
      color: #ffffff;
    }

    /* ── Results head ────────────────── */
    .results-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-3) 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
    }

    .results-head p { margin: 0; }
    .results-head strong { color: var(--color-text); }

    .results-head-right {
      display: flex;
      align-items: center;
      gap: var(--space-4);
    }

    /* ── View toggle ─────────────────── */
    .view-toggle {
      display: flex;
      gap: 2px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: 3px;
      background: var(--color-surface-raised);
    }

    .view-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 34px;
      border: none;
      border-radius: calc(var(--radius-md) - 2px);
      background: transparent;
      color: var(--color-text-dim);
      cursor: pointer;
      transition: background 0.15s ease, color 0.15s ease;
      padding: 0;
    }

    .view-btn:hover {
      background: var(--color-primary-glow);
      color: var(--color-primary);
      box-shadow: none;
      transform: none;
    }

    .view-btn.active {
      background: var(--color-primary);
      color: #F8FAFC;
    }

    /* ── Active filters ───────────────── */
    .active-filters {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
      margin-top: calc(var(--space-3) * -1);
    }

    /* ── Results section ─────────────── */
    .results {
      display: grid;
      gap: var(--space-3);
    }

    .results h2 {
      margin: 0;
      font-size: var(--font-size-base);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--color-text-dim);
    }

    /* ── Audience-based card visibility (CSS-driven) ─ */
    #results-section[data-audience="teacher"] .result-card:not([data-audiences~="teacher"]) { display: none; }
    #results-section[data-audience="student"]  .result-card:not([data-audiences~="student"])  { display: none; }
    #results-section[data-audience="community"] .result-card:not([data-audiences~="community"]) { display: none; }

    /* Table rows */
    #results-section[data-audience="teacher"] tr[data-audiences]:not([data-audiences~="teacher"]) { display: none; }
    #results-section[data-audience="student"]  tr[data-audiences]:not([data-audiences~="student"])  { display: none; }
    #results-section[data-audience="community"] tr[data-audiences]:not([data-audiences~="community"]) { display: none; }

    /* Pedagogical tag chips — only visible in teacher view */
    #results-section:not([data-audience="teacher"]) .chip-pedagogical { display: none; }

    /* Pedagogical column header in table — only visible in teacher view */
    #results-section:not([data-audience="teacher"]) .th-pedagogical,
    #results-section:not([data-audience="teacher"]) .td-pedagogical { display: none; }

    /* ── Cards ─────────────────────────── */
    .result-card { border: 1px solid var(--color-border); border-radius: var(--radius-lg); background: var(--color-surface); transition: border-color 0.15s ease; display: grid; grid-template-columns: 1fr; }
    .result-card:hover { border-color: var(--color-border-highlight); }

    .result-main {
      padding: var(--space-5);
      display: grid;
      gap: var(--space-3);
    }

    .result-main h3 {
      margin: 0;
      font-size: var(--font-size-lg);
      letter-spacing: -0.02em;
    }

    .result-main h3 a {
      color: var(--color-text);
      transition: color 0.15s ease;
    }

    .result-main h3 a:hover {
      color: var(--color-primary);
      text-decoration: none;
    }

    .result-main p {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
      line-height: var(--line-height-relaxed);
    }

    .meta-line {
      color: var(--color-text-dim);
      font-family: var(--font-mono);
      font-size: var(--font-size-xs);
    }

    /* ── Chips ─────────────────────────── */
    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .chip {
      display: inline-flex;
      align-items: center;
      padding: 2px var(--space-2);
      border-radius: var(--radius-sm);
      border: 1px solid var(--color-border);
      font-size: var(--font-size-xs);
      font-weight: 500;
      color: var(--color-text-muted);
      background: var(--color-surface-raised);
    }

    .chip-theme {
      border-color: rgba(21, 94, 117, 0.25);
      color: var(--color-secondary);
      background: rgba(21, 94, 117, 0.08);
    }

    .chip-pedagogical {
      border-color: rgba(14, 114, 101, 0.25);
      color: var(--color-primary);
      background: var(--color-primary-glow);
    }

    .result-card.empty { padding: var(--space-8); text-align: center; }
    .result-card.empty p { margin: 0; color: var(--color-text-dim); }

    /* ── View logic ───────────────────── */
    .cards-view { display: grid; gap: var(--space-3); }
    .table-view { display: none; }

    /* List view */
    #results-section[data-view="list"] .cards-view { display: grid; }
    #results-section[data-view="list"] .result-card { grid-template-columns: 1fr; }

    /* Grid view */
    #results-section[data-view="grid"] .cards-view {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    @media (min-width: 640px) {
      #results-section[data-view="grid"] .cards-view {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    #results-section[data-view="grid"] .result-card {
      grid-template-columns: 1fr;
      display: flex;
      flex-direction: column;
    }

    #results-section[data-view="grid"] .result-main { flex: 1; }

    /* Table view */
    #results-section[data-view="table"] .cards-view { display: none; }

    #results-section[data-view="table"] .table-view {
      display: block;
      overflow-x: auto;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-surface);
    }

    .table-view table {
      width: 100%;
      border-collapse: collapse;
      font-size: var(--font-size-sm);
    }

    .table-view thead {
      background: var(--color-surface-raised);
      border-bottom: 1px solid var(--color-border);
    }

    .table-view th {
      text-align: left;
      padding: var(--space-3) var(--space-4);
      font-size: var(--font-size-xs);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--color-text-dim);
      white-space: nowrap;
    }

    .table-view td {
      padding: var(--space-3) var(--space-4);
      border-bottom: 1px solid var(--color-border);
      vertical-align: middle;
    }

    .table-view tbody tr:last-child td { border-bottom: none; }
    .table-view tbody tr:hover { background: var(--color-primary-glow); }

    .td-title { font-weight: 600; color: var(--color-text); min-width: 200px; }
    .td-title a { color: var(--color-text); transition: color 0.15s ease; }
    .td-title a:hover { color: var(--color-primary); text-decoration: none; }
    .td-meta { color: var(--color-text-dim); white-space: nowrap; font-family: var(--font-mono); font-size: var(--font-size-xs); }
  </style>
</Layout>

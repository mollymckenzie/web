---
import Layout from '@layouts/Layout.astro';
import { withBasePath } from '@lib/paths';

const teacherHref = withBasePath('/complete-catalog?audience=teacher');
const studentHref = withBasePath('/complete-catalog?audience=student');
const communityHref = withBasePath('/complete-catalog?audience=community');
---

<Layout
  title="Example Community Library"
  description="A sample community-specific CDL entry for Knox County."
>
  <section class="example-shell">
    <header class="hero">
      <p class="eyebrow">Example Community Library</p>
      <h1>Welcome to the Knox County Community Data Library</h1>
      <p>
        This sample entry shows how a local CDL could guide visitors into role-based dataset exploration.
      </p>
    </header>

    <section class="role-picker" aria-label="Choose your role">
      <h2>I am a...</h2>
      <div class="role-grid">
        <a href={teacherHref} class="role-card">
          <h3>Teacher</h3>
          <p>Open the complete catalog with pedagogical tags and classroom planning support.</p>
        </a>
        <a href={studentHref} class="role-card">
          <h3>Student</h3>
          <p>Open the student-safe catalog view with sensitive datasets excluded.</p>
        </a>
        <a href={communityHref} class="role-card">
          <h3>Community Member</h3>
          <p>Open the community discovery view for local exploration and outreach.</p>
        </a>
      </div>
    </section>

    <section class="composition" aria-label="Composition of community data library">
      <h2>Composition of Community Data Library</h2>
      <ul>
        <li>
          Community Catalog
          : Localized dataset access through the role-based complete catalog views.
        </li>
        <li>
          Data Resources
          : Submission, lesson plans, and community activities entry points.
        </li>
        <li>
          Suggest a Resource
          : <a href={withBasePath('/submit')}>Submit a resource</a> to propose additions.
        </li>
      </ul>
    </section>
  </section>

  <style>
    .example-shell {
      display: grid;
      gap: var(--space-8);
    }

    .hero {
      display: grid;
      gap: var(--space-3);
      max-width: 72ch;
    }

    .eyebrow {
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: var(--font-size-xs);
      font-weight: 700;
      color: var(--color-secondary);
    }

    .hero h1 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 3.25rem);
    }

    .hero p {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-lg);
    }

    .role-picker {
      display: grid;
      gap: var(--space-4);
    }

    .role-picker h2,
    .composition h2 {
      margin: 0;
      font-size: var(--font-size-2xl);
    }

    .role-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    @media (min-width: 900px) {
      .role-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    .role-card {
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      border-radius: var(--radius-xl);
      padding: var(--space-5);
      display: grid;
      gap: var(--space-2);
      color: inherit;
      text-decoration: none;
      box-shadow: var(--shadow-sm);
      transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
    }

    .role-card:hover {
      text-decoration: none;
      border-color: var(--color-primary);
      box-shadow: var(--shadow-md);
      transform: translateY(-1px);
    }

    .role-card h3 {
      margin: 0;
      font-size: var(--font-size-xl);
    }

    .role-card p {
      margin: 0;
      color: var(--color-text-muted);
      line-height: var(--line-height-relaxed);
    }

    .composition {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      background: var(--color-surface);
      padding: var(--space-5);
      display: grid;
      gap: var(--space-3);
    }

    .composition ul {
      margin: 0;
      padding-left: 1.2rem;
      display: grid;
      gap: var(--space-2);
    }

    .composition li {
      color: var(--color-text-muted);
      line-height: var(--line-height-relaxed);
    }
  </style>
</Layout>

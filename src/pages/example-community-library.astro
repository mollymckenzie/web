---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { canAudienceAccess } from '@lib/data/libraryAccess';
import { withBasePath } from '@lib/paths';

const allResources = await getCollection('master-library');

// Knox County community library: datasets tagged with 'knox-county'
const knoxResources = allResources.filter(r => r.data.tags.includes('knox-county'));

// Sort by most recent
const sorted = [...knoxResources].sort((a, b) => {
  const at = a.data.publishedDate ? new Date(a.data.publishedDate).getTime() : 0;
  const bt = b.data.publishedDate ? new Date(b.data.publishedDate).getTime() : 0;
  return bt - at;
});

function getAudiences(resource: (typeof allResources)[number]): string {
  const audiences: string[] = [];
  if (canAudienceAccess(resource, 'teacher')) audiences.push('teacher');
  if (canAudienceAccess(resource, 'student')) audiences.push('student');
  if (canAudienceAccess(resource, 'community')) audiences.push('community');
  return audiences.join(' ');
}

function formatDate(date: Date | undefined): string {
  if (!date) return '';
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const submitHref = withBasePath('/submit');
---

<Layout
  title="Knox County Community Data Library"
  description="A community-specific data library for Knox County, Tennessee — with role-based catalog views for teachers, students, and community members."
>
  <div class="cdl-shell">

    <!-- ── Hero ──────────────────────────────────────── -->
    <header class="hero">
      <p class="eyebrow">Example Community Library</p>
      <h1>Welcome to the Knox County<br/>Community Data Library</h1>
      <p class="hero-sub">
        Explore local datasets curated for Knox County, Tennessee.
        Choose your role below to get a tailored view of the catalog.
      </p>
    </header>

    <!-- ── Role picker ───────────────────────────────── -->
    <section class="role-picker" aria-label="Choose your role">
      <h2>I am a&hellip;</h2>
      <div class="role-grid">
        <button class="role-card role-card-teacher active" data-audience="teacher">
          <h3>Teacher</h3>
          <p>Full catalog with pedagogical tags and classroom planning support.</p>
        </button>
        <button class="role-card role-card-student" data-audience="student">
          <h3>Student</h3>
          <p>Student-safe view with sensitive datasets removed.</p>
        </button>
        <button class="role-card role-card-community" data-audience="community">
          <h3>Community Member</h3>
          <p>Complete unfiltered catalog for local exploration.</p>
        </button>
      </div>
    </section>

    <!-- ── Catalog ───────────────────────────────────── -->
    <section class="catalog" id="knox-catalog" data-audience="teacher" aria-label="Knox County datasets">
      <div class="catalog-header">
        <h2 id="catalog-heading">Knox County Datasets — Teacher View</h2>
        <p id="catalog-count"><strong>{sorted.length}</strong> datasets</p>
      </div>

      {sorted.length === 0 ? (
        <p class="empty">No datasets found for Knox County yet.</p>
      ) : (
        <div class="cards">
          {sorted.map(resource => {
            const themes = resource.data.dataThemes.length > 0 ? resource.data.dataThemes : resource.data.tags.filter(t => t !== 'knox-county' && t !== 'local' && t !== 'tennessee');
            const previewHref = withBasePath(`/data-preview?entry=${encodeURIComponent(resource.id)}&audience=AUDIENCE_PLACEHOLDER`);
            const resourceAudiences = getAudiences(resource);
            return (
              <article class="dataset-card" data-audiences={resourceAudiences}>
                <div class="card-body">
                  <h3><a href={previewHref} class="preview-link">{resource.data.title}</a></h3>
                  <p>{resource.data.description}</p>
                  <div class="chips">
                    {themes.slice(0, 3).map(t => <span class="chip chip-theme">{t}</span>)}
                    {resource.data.pedagogicalTags.slice(0, 2).map(t => (
                      <span class="chip chip-pedagogical">{t}</span>
                    ))}
                  </div>
                  {resource.data.publishedDate && (
                    <p class="meta">Updated {formatDate(resource.data.publishedDate)}</p>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      )}
    </section>

    <!-- ── Composition ───────────────────────────────── -->
    <section class="composition" aria-label="About this library">
      <h2>About This Library</h2>
      <ul>
        <li>
          <strong>Community Catalog</strong> — Datasets curated specifically for Knox County, TN,
          accessible through role-based views above.
        </li>
        <li>
          <strong>Data Resources</strong> — Lesson plans, community activities, and submission tools
          are available under <a href={withBasePath('/data-resources')}>Data Resources</a>.
        </li>
        <li>
          <strong>Suggest a Resource</strong> — Know a dataset that belongs here?
          <a href={submitHref}>Submit a resource</a> to propose it for the catalog.
        </li>
      </ul>
    </section>

  </div>

  <script>
    const catalog = document.getElementById('knox-catalog');
    const heading = document.getElementById('catalog-heading');
    const countEl = document.getElementById('catalog-count');
    const rolePills = document.querySelectorAll<HTMLElement>('.role-card[data-audience]');

    const headingLabels: Record<string, string> = {
      teacher: 'Knox County Datasets — Teacher View',
      student: 'Knox County Datasets — Student View',
      community: 'Knox County Datasets — Community View',
    };

    function applyAudience(audience: string) {
      if (!catalog) return;
      catalog.dataset.audience = audience;

      // Update role card active state
      rolePills.forEach(pill => {
        pill.classList.toggle('active', pill.dataset.audience === audience);
      });

      // Update heading
      if (heading) heading.textContent = headingLabels[audience] ?? headingLabels.community;

      // Update preview link hrefs
      document.querySelectorAll<HTMLAnchorElement>('.preview-link').forEach(link => {
        link.href = link.href.replace(/audience=[^&]+/, `audience=${audience}`);
      });

      // Update count (only visible cards)
      if (countEl) {
        const allCards = catalog.querySelectorAll<HTMLElement>('.dataset-card');
        let count = 0;
        allCards.forEach(card => {
          if ((card.dataset.audiences ?? '').split(' ').includes(audience)) count++;
        });
        countEl.innerHTML = `<strong>${count}</strong> datasets`;
      }
    }

    rolePills.forEach(pill => {
      pill.addEventListener('click', () => {
        applyAudience(pill.dataset.audience ?? 'community');
      });
    });

    applyAudience('teacher');
  </script>

  <style>
    .cdl-shell {
      display: grid;
      gap: var(--space-10);
    }

    /* ── Hero ─────────────────── */
    .hero {
      display: grid;
      gap: var(--space-3);
      max-width: 72ch;
    }

    .eyebrow {
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: var(--font-size-xs);
      font-weight: 700;
      color: var(--color-secondary);
    }

    .hero h1 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 3.25rem);
      line-height: 1.15;
    }

    .hero-sub {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-lg);
      line-height: var(--line-height-relaxed);
    }

    /* ── Role picker ──────────── */
    .role-picker {
      display: grid;
      gap: var(--space-4);
    }

    .role-picker h2 {
      margin: 0;
      font-size: var(--font-size-2xl);
    }

    .role-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    @media (min-width: 900px) {
      .role-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    .role-card {
      /* Reset button defaults */
      appearance: none;
      -webkit-appearance: none;
      font-family: var(--font-sans);
      font-size: inherit;
      width: 100%;
      /* Card styles */
      border: 2px solid var(--color-border);
      background: var(--color-surface);
      border-radius: var(--radius-xl);
      padding: var(--space-5);
      display: grid;
      gap: var(--space-2);
      text-align: left;
      cursor: pointer;
      transition: border-color 0.15s ease, background 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
    }

    .role-card:hover {
      transform: translateY(-1px);
      box-shadow: var(--shadow-sm);
    }

    .role-card.active {
      border-color: var(--color-primary);
      background: var(--color-primary-glow);
    }

    .role-card-student.active {
      border-color: var(--color-secondary);
      background: rgba(21, 94, 117, 0.06);
    }

    .role-card-community.active {
      border-color: rgba(26, 107, 69, 0.7);
      background: rgba(26, 107, 69, 0.06);
    }

    .role-card h3 {
      margin: 0;
      font-size: var(--font-size-xl);
      color: var(--color-text);
    }

    .role-card p {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
      line-height: var(--line-height-relaxed);
    }

    /* ── Catalog ──────────────── */
    .catalog {
      display: grid;
      gap: var(--space-4);
    }

    .catalog-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
      flex-wrap: wrap;
      border-bottom: 1px solid var(--color-border);
      padding-bottom: var(--space-3);
    }

    .catalog-header h2 {
      margin: 0;
      font-size: var(--font-size-xl);
    }

    .catalog-header p {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
    }

    .catalog-header strong {
      color: var(--color-text);
    }

    .cards {
      display: grid;
      gap: var(--space-3);
    }

    /* Audience-driven visibility */
    #knox-catalog[data-audience="teacher"] .dataset-card:not([data-audiences~="teacher"]) { display: none; }
    #knox-catalog[data-audience="student"]  .dataset-card:not([data-audiences~="student"])  { display: none; }
    #knox-catalog[data-audience="community"] .dataset-card:not([data-audiences~="community"]) { display: none; }

    /* Pedagogical chips only in teacher view */
    #knox-catalog:not([data-audience="teacher"]) .chip-pedagogical { display: none; }

    .dataset-card {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-surface);
      transition: border-color 0.15s ease;
    }

    .dataset-card:hover {
      border-color: var(--color-border-highlight);
    }

    .card-body {
      padding: var(--space-5);
      display: grid;
      gap: var(--space-3);
    }

    .card-body h3 {
      margin: 0;
      font-size: var(--font-size-lg);
      letter-spacing: -0.02em;
    }

    .card-body h3 a {
      color: var(--color-text);
      text-decoration: none;
      transition: color 0.15s ease;
    }

    .card-body h3 a:hover {
      color: var(--color-primary);
    }

    .card-body > p {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
      line-height: var(--line-height-relaxed);
    }

    .meta {
      color: var(--color-text-dim);
      font-family: var(--font-mono);
      font-size: var(--font-size-xs);
    }

    .empty {
      color: var(--color-text-dim);
      font-style: italic;
    }

    /* ── Chips ────────────────── */
    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .chip {
      display: inline-flex;
      align-items: center;
      padding: 2px var(--space-2);
      border-radius: var(--radius-sm);
      border: 1px solid var(--color-border);
      font-size: var(--font-size-xs);
      font-weight: 500;
      color: var(--color-text-muted);
      background: var(--color-surface-raised);
    }

    .chip-theme {
      border-color: rgba(21, 94, 117, 0.25);
      color: var(--color-secondary);
      background: rgba(21, 94, 117, 0.08);
    }

    .chip-pedagogical {
      border-color: rgba(14, 114, 101, 0.25);
      color: var(--color-primary);
      background: var(--color-primary-glow);
    }

    /* ── Composition ──────────── */
    .composition {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-xl);
      background: var(--color-surface);
      padding: var(--space-6);
      display: grid;
      gap: var(--space-3);
    }

    .composition h2 {
      margin: 0;
      font-size: var(--font-size-xl);
    }

    .composition ul {
      margin: 0;
      padding-left: 1.2rem;
      display: grid;
      gap: var(--space-3);
    }

    .composition li {
      color: var(--color-text-muted);
      line-height: var(--line-height-relaxed);
      font-size: var(--font-size-sm);
    }

    .composition a {
      color: var(--color-primary);
    }
  </style>
</Layout>

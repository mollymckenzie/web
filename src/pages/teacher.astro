---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { extractPedagogicalTags, extractThemes } from '@lib/data/libraryAccess';
import { withBasePath } from '@lib/paths';

const resources = await getCollection('master-library');
const dataThemes = extractThemes(resources, 'teacher');
const pedagogicalTags = extractPedagogicalTags(resources);
---

<Layout
  title="Teacher"
  description="Resources curated for teachers using data in classrooms and learning spaces."
>
  <section class="role-shell">
    <header class="role-header">
      <div class="role-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
      </div>
      <div>
        <h1>Teacher View</h1>
        <p class="role-desc">
          Classroom-ready datasets, guides, and resources to support data literacy and project-based learning.
        </p>
      </div>
    </header>

    <a href={withBasePath('/complete-catalog?audience=teacher')} class="button cta-button">Open Complete Catalog as Teacher &rarr;</a>

    <div class="panel-grid">
      <article class="panel">
        <h2>Data Themes</h2>
        {dataThemes.length > 0 ? (
          <ul>
            {dataThemes.map((theme) => (
              <li>{theme}</li>
            ))}
          </ul>
        ) : (
          <p class="empty-note">No themes available yet.</p>
        )}
      </article>

      <article class="panel">
        <h2>Pedagogical Tags</h2>
        {pedagogicalTags.length > 0 ? (
          <ul>
            {pedagogicalTags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        ) : (
          <p class="empty-note">No tags available yet.</p>
        )}
      </article>
    </div>

    <div class="info-card">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <p>Teacher view includes all resources, including datasets that may be excluded from student view (e.g., sensitive topics like opioid addiction data).</p>
    </div>
  </section>

  <style>
    .role-shell {
      display: grid;
      gap: var(--space-6);
      max-width: 900px;
    }

    .role-header {
      display: flex;
      align-items: flex-start;
      gap: var(--space-4);
    }

    .role-icon {
      width: 52px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: color-mix(in srgb, var(--color-primary) 10%, var(--color-surface));
      border-radius: var(--radius-lg);
      color: var(--color-primary);
      flex-shrink: 0;
    }

    .role-header h1 {
      margin-bottom: var(--space-2);
    }

    .role-desc {
      color: var(--color-text-muted);
      font-size: var(--font-size-lg);
      margin: 0;
    }

    .cta-button {
      display: inline-flex;
      align-items: center;
      align-self: start;
    }

    .panel-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }

    @media (min-width: 768px) {
      .panel-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    .panel {
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
    }

    .panel h2 {
      margin-bottom: var(--space-4);
      font-size: var(--font-size-base);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-text-muted);
    }

    .panel ul {
      margin: 0;
      padding-left: 1.25rem;
      display: grid;
      gap: var(--space-2);
      font-size: var(--font-size-sm);
    }

    .empty-note {
      margin: 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
    }

    .info-card {
      display: flex;
      gap: var(--space-3);
      align-items: flex-start;
      padding: var(--space-4) var(--space-5);
      background: color-mix(in srgb, var(--color-primary) 6%, var(--color-surface));
      border: 1px solid color-mix(in srgb, var(--color-primary) 20%, var(--color-border));
      border-radius: var(--radius-lg);
      color: var(--color-primary);
    }

    .info-card svg {
      flex-shrink: 0;
      margin-top: 2px;
    }

    .info-card p {
      margin: 0;
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
      line-height: var(--line-height-relaxed);
    }
  </style>
</Layout>
